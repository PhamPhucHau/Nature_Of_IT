# ==========================================
# File:
# web_server/language/C/phase1/makefile
# ==========================================

CC = gcc

CFLAGS = -Wall -Wextra -O2 -g

LDFLAGS = -lpthread

TARGET = server

SRC = 01_basic_socket.c

# ==========================================
# Build
# ==========================================
build:
	$(CC) $(CFLAGS) $(SRC) -o $(TARGET) $(LDFLAGS)

# ==========================================
# Run
# ==========================================
run:
	./$(TARGET)

# ==========================================
# Clean
# ==========================================
clean:
	rm -f $(TARGET)

# ==========================================
# Rebuild
# ==========================================
rebuild: clean build