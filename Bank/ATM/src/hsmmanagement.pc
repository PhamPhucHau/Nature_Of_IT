	char l_pan[12 + 1] = {0x00, };;
	snprintf(l_pan,sizeof(l_pan), "%.12s", INPUT->atm_pan_ctt + (strlen(INPUT->atm_pan_ctt) -12 -1 ) );  // 12 right-most digits , exclude check digit

	// memset(s_cmdM6, 0x00, sizeof(s_cmdM6) );
