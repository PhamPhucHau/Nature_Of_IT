int smartDecrypt(hsmManagementContext *context)   
{

	if(strlen(INPUT->atm_pan_ctt) < 1){
		LOGGER(LOG_ERROR, "PAN is mandatory", "");
		return ABNORMAL;
	}
	if(strlen(INPUT->dest_zpk_ctt) < 1){   
		LOGGER(LOG_ERROR, "Zpk is mandatory", "");
		return ABNORMAL;
	}
	if(strlen(INPUT->atm_psn_pin_nw) < 1){    
		LOGGER(LOG_ERROR, "Block Pin is mandatory", "");
		return ABNORMAL;
	}

	char r_code[3] = {0x00,};
	char encPin[33 +1] = {0x00,};
	  
	if(translatePinZpkToLmk(context) != NORMAL){
		return ABNORMAL;
	}       
	
	memcpy(&r_cmdJF, context->hsm_recvBuffer, sizeof(r_cmdJF) );
	
	if(memcmp(r_cmdJF.errcode, "00", 2 ) != 0){
		LOGGER(LOG_ERROR,  "translatePinZpkToLmk error [%.*s]", sizeof(r_cmdJF.errcode), r_cmdJF.errcode);
		return ABNORMAL;
	}
	memcpy(INPUT->atm_psn_pin_nw, r_cmdJF.encpin, 33);
	if(decryptPINByLmk(context) != NORMAL){
		return ABNORMAL;      
	}

	memcpy(&r_cmdNH, context->hsm_recvBuffer, sizeof(r_cmdNH) );
	char pin_buff[LEN_HSM_PIN_BUFF + 1] = {0x00,};
	memcpy(pin_buff, r_cmdNH.pin , sizeof(r_cmdNH.pin));

	//remove padding
	int ix = 0;
	for(ix = 0; ix < strlen(pin_buff);ix++){   
		if(pin_buff[ix] < '0' || pin_buff[ix] > '9'  ){
			pin_buff[ix] = '';   
			break;
		}
	}    

	memcpy(OUTPUT->atm_psn_pin_nw, pin_buff , strlen(pin_buff));
	memcpy(OUTPUT->atm_respond_c, r_cmdNH.errcode, sizeof(OUTPUT->atm_respond_c) -1);
        
	return NORMAL;
}

int smartEncrypt(hsmManagementContext *context)
{
	if(strlen(INPUT->atm_pan_ctt) < 1){
		LOGGER(LOG_ERROR, "PAN is mandatory", "");
		return ABNORMAL;
	}
	if(strlen(INPUT->dest_zpk_ctt) < 1){
		LOGGER(LOG_ERROR, "Zpk is mandatory", "");
		return ABNORMAL;
	}
	if(strlen(INPUT->atm_psn_pin_nw) < 1){
		LOGGER(LOG_ERROR, "Block Pin is mandatory", "");
		return ABNORMAL;
	}

	char r_code[3] = {0x00,};
	char encPin[33 +1] = {0x00,};
	
	if(encPinUnderLmk(context) != NORMAL){
		return ABNORMAL;   
	}
	memcpy(&r_cmdBB, context->hsm_recvBuffer, sizeof(r_cmdBB) );
	
	if(memcmp(r_cmdBB.errcode, "00", 2 ) != 0){
		LOGGER(LOG_ERROR,  "Encrypt Pin Under LMK error [%.*s]", sizeof(r_cmdBB.errcode), r_cmdBB.errcode);
		return ABNORMAL;
	}
	
	memcpy(INPUT->atm_psn_pin_nw, r_cmdBB.encpin, 33);
	if(translatePinLmkToZpk(context) != NORMAL){
		return ABNORMAL;
	}
	memcpy(&r_cmdJH, context->hsm_recvBuffer, sizeof(r_cmdJH) );
	memcpy(OUTPUT->atm_respond_c, r_cmdJH.errcode, sizeof(OUTPUT->atm_respond_c) -1);
	memcpy(OUTPUT->atm_psn_pin_nw, r_cmdJH.pinblock, sizeof(OUTPUT->atm_psn_pin_nw) -1);

	return NORMAL;
}

int smartDecryptNAP(hsmManagementContext *context)   
{

	if(strlen(INPUT->atm_pan_ctt) < 1){
		LOGGER(LOG_ERROR, "PAN is mandatory", "");
		return ABNORMAL;
	}
	if(strlen(INPUT->dest_zpk_ctt) < 1){
		LOGGER(LOG_ERROR, "Zpk is mandatory", "");
		return ABNORMAL;              
	}
	if(strlen(INPUT->atm_psn_pin_nw) < 1){
		LOGGER(LOG_ERROR, "Block Pin is mandatory", "");      
		return ABNORMAL;
	}

	char r_code[3] = {0x00,};
	char encPin[33 +1] = {0x00,};
	        
	if(translatePinZpkToLmkNAP(context) != NORMAL){
		return ABNORMAL;   
	}       
	
	memcpy(&r_cmdJF, context->hsm_recvBuffer, sizeof(r_cmdJF) );
	
	if(memcmp(r_cmdJF.errcode, "00", 2 ) != 0){
		LOGGER(LOG_ERROR,  "translatePinZpkToLmk error [%.*s]", sizeof(r_cmdJF.errcode), r_cmdJF.errcode);
		return ABNORMAL;
	}
	memcpy(INPUT->atm_psn_pin_nw, r_cmdJF.encpin, 33);
	if(decryptPINByLmkNAP(context) != NORMAL){
		return ABNORMAL;      
	}

	memcpy(&r_cmdNH, context->hsm_recvBuffer, sizeof(r_cmdNH) );

	char pin_buff[LEN_HSM_PIN_BUFF + 1] = {0x00,};
	memcpy(pin_buff, r_cmdNH.pin , sizeof(r_cmdNH.pin ));

	//remove padding
	int ix = 0;
	for(ix = 0; ix < strlen(pin_buff);ix++){   
		if(pin_buff[ix] < '0' || pin_buff[ix] > '9'  ){
			pin_buff[ix] = '';   
			break;  
		}
	}    
	memcpy(OUTPUT->atm_psn_pin_nw, pin_buff , strlen(pin_buff));
	memcpy(OUTPUT->atm_respond_c, r_cmdNH.errcode, sizeof(OUTPUT->atm_respond_c) -1);
        
	return NORMAL;
}

void removeSpace(char* sourceStr, char* destStr)
{

	while(*sourceStr != ''){

		if(*sourceStr != 0x20){
			*destStr = *sourceStr;
			destStr++;
		}
		sourceStr++;
	}
	*destStr = '';
}


