typedef struct
{    
    int     hport;
    char    haddr[20];
} s_hostaddr;    

s_hostaddr S_HOSTADDR_HSM[2];
int hostCnt;    
  


int hsmManagement(hsmManagement_in * input, hsmManagement_out *output )
{
	hsmManagementContext __context;  
    hsmManagementContext *context = &__context;
	
	bzero(context, sizeof(hsmManagementContext));   
    context->input = input;  
    context->output = output;            

	memset(&s_cmdA6, 0 , sizeof(s_cmdA6));
	memset(&s_cmdBA, 0 , sizeof(s_cmdBA));
	memset(&s_cmdCC, 0 , sizeof(s_cmdCC));
	memset(&s_cmdJE, 0 , sizeof(s_cmdJE));
	memset(&s_cmdJG, 0 , sizeof(s_cmdJG));
	memset(&s_cmdM6, 0 , sizeof(s_cmdM6));
	memset(&s_cmdM8, 0 , sizeof(s_cmdM8));
	memset(&s_cmdNG, 0 , sizeof(s_cmdNG));
	memset(&r_cmdA7, 0 , sizeof(r_cmdA7));
	memset(&r_cmdBB, 0 , sizeof(r_cmdBB));
	memset(&r_cmdCD, 0 , sizeof(r_cmdCD));     
	memset(&r_cmdJF, 0 , sizeof(r_cmdJF));
	memset(&r_cmdJH, 0 , sizeof(r_cmdJH));
	memset(&r_cmdM7, 0 , sizeof(r_cmdM7));
	memset(&r_cmdM9, 0 , sizeof(r_cmdM9));
	memset(&r_cmdNH, 0 , sizeof(r_cmdNH));
	  
	if( INPUT->brd_connt_port_no == 0 || strlen(INPUT->tmn_ip) == 0 ){
		LOGGER(LOG_ERROR, "Remoted Ip/Port is mandatory", "");
		return ABNORMAL;
	}     
	  
	if(strlen(INPUT->rqst_svc_c) == 0){
		LOGGER(LOG_ERROR, "Remoted Service ID is mandatory", "");
		return ABNORMAL;
	}

	LOGGER(LOG_INFO, "hsmManagement start FUNC[%d -%s]", INPUT->trx_func_d, INPUT->rqst_svc_c);
	switch(INPUT->trx_func_d)
	{
		case TRX_D_IMPORT_ZPKKEY:
			if(importZpkKey(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_IMPORT_MAKKEY:
			if(importMakKey(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_GENMAC:
			if(generateMAC(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_VERMAC:
			if(verifyMAC(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_TLTPIN_ZPKZPK:
			if(translatePinZpkToZpk(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_ENCPIN_LMK:
			if(encPinUnderLmk(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_TLTPIN_LMKZPK:
			if(translatePinLmkToZpk(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_TLTPIN_ZPKLMK:
			if(translatePinZpkToLmk(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_DECPIN_LMK:
			if(decryptPINByLmk(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_DECPIN_SMRT:  
			if(smartDecrypt(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}  
		break;
		case TRX_D_ENCPIN_SMRT:
			if(smartEncrypt(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}
		break;
		case TRX_D_DECPIN_SMRT_NAP:  
			if(smartDecryptNAP(context) != NORMAL ){
				memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);
			}  
		break;
		default :
			LOGGER(LOG_ERROR, "hsmManagement Faile func[%d]",INPUT->trx_func_d);
			memcpy(OUTPUT->atm_respond_c, "90", sizeof(OUTPUT->atm_respond_c) -1);  
		break;
	}    
	if (context->sockfd_hsm > 0){
    	close(context->sockfd_hsm);
    	context->sockfd_hsm = -1;
    }
	LOGGER(LOG_INFO, "hsmManagement end FUNC[%d -%s]",INPUT->trx_func_d,OUTPUT->atm_respond_c);
	return NORMAL;
}

/*----------------------------------------------------------------------------  	*/
/* SUBJECT  : Check response message			                                    */
/* ARGUMENT :                                                                   	*/
/*                                                   								*/
/* RETURN   : SUCCESS: NORMAL                                                   	*/
/*----------------------------------------------------------------------------		*/
static long checkResp(hsmManagementContext *context, char *respCode)
{
	if(strncmp(context->hsm_recvBuffer + 4, respCode, 2 ) != 0)
	{
		return ABNORMAL;
	}
	memcpy( context->r_data, context->hsm_recvBuffer, sizeof(context->r_data));
	memcpy(	context->r_code, &context->hsm_recvBuffer[6], 2 );
	return NORMAL;
}
/*----------------------------------------------------------------------------  	*/
/* SUBJECT  : Connect to HSM Via PCI queue		                                    */
/* ARGUMENT :                                                                   	*/
/*                                                   								*/
/* RETURN   : SUCCESS: NORMAL                                                   	*/
/*----------------------------------------------------------------------------		*/
static long initClientUnixSocket(hsmManagementContext *context, long timeout_ms)
{  
	context->sockfd_hsm = -1;
	char socketPath[300];
	bzero(&socketPath, sizeof(socketPath));
	
	snprintf(socketPath,sizeof(socketPath), "%s%ssckttmp", UNIX_SOCKET_PATH_HSM, INPUT->rqst_svc_c);

	LOGGER(LOG_DEBUG,  " Connection Unix Socket start [%s]",socketPath);
	context->sockfd_hsm = socket(AF_UNIX, SOCK_STREAM, 0);
	struct sockaddr_un addr;
	memset(&addr,0,sizeof(addr));
	addr.sun_family = AF_UNIX;  
	memcpy(addr.sun_path, socketPath, sizeof(addr.sun_path));    

	int rc = 0;
	int sockfd_flags_before;
	if( ( sockfd_flags_before=fcntl(context->sockfd_hsm, F_GETFL,0) ) < 0 ) return ABNORMAL;
	if( fcntl( context->sockfd_hsm, F_SETFL, sockfd_flags_before | O_NONBLOCK ) < 0 ) return ABNORMAL;
	// Start connection asyncronously
	do{
		if(connect(context->sockfd_hsm, (struct sockaddr*)&addr, sizeof(addr)) < 0)
        {
            //Did connection return an error? If so , we'll fail
            if( (errno != EWOULDBLOCK) && (errno != EINPROGRESS) ){
            	rc = -1;
            }else{
				struct timespec now;	
				if(clock_gettime(CLOCK_MONOTONIC, &now) < 0 ){
					rc = -1; 
					break;
				}         
				struct timespec deadline = {
						.tv_sec = now.tv_sec ,
						.tv_nsec = now.tv_nsec + timeout_ms*1000000l}; 
				do{
					if(clock_gettime(CLOCK_MONOTONIC, &now) < 0 ){
						rc = -1; 
						break;
					}  
					// Calculate how long until deadline
					int ms_until_deadline = (int)( (deadline.tv_sec - now.tv_sec)*1000l + 
												   (deadline.tv_nsec - now.tv_nsec)/1000000l);
					if(ms_until_deadline < 0){
						rc = 0;
						break;
					}    
					// Wait for connect to complete( or for the timeout deadline )
					struct pollfd pfds[] = { {.fd = context->sockfd_hsm, .events = POLLOUT} };
					rc = poll(pfds, 1, ms_until_deadline);
					// If poll secceeded , make sure it really succeeded
					if(rc > 0){
						int error = 0; socklen_t len = sizeof(error);
						int reval = getsockopt(context->sockfd_hsm, SOL_SOCKET, SO_ERROR, &error, &len);
						if(reval == 0 ) errno = error;
						if( error  != 0 ){ 
							rc = -1;
							LOGGER(LOG_ERROR,  " Connection Unix Socket Failed", "");
						}
					}
				}
				
				// If poll was interrupted , tru again.
				while( rc ==-1 && errno==EINTR );	
				// Did poll timeout? If so , fail.
				if(rc == 0){
					errno = ETIMEDOUT;
					LOGGER(LOG_ERROR,  " Connection Unix Socket Timeout", "");
					rc = -1;
				}
            }
        }
	}while(0);
	if( fcntl(context->sockfd_hsm, F_SETFL, sockfd_flags_before) < 0 ) return ABNORMAL;
	return (rc < 0 ? ABNORMAL : NORMAL );	
}

/*----------------------------------------------------------------------------  	*/
/* SUBJECT  : Connect to HSM Via TCP/IP  		                                    */
/* ARGUMENT :                                                                   	*/
/*                                                   								*/
/* RETURN   : SUCCESS: NORMAL                                                   	*/
/*----------------------------------------------------------------------------		*/
static long initSocket(hsmManagementContext *context, long timeout_ms)
{
	int rc = 0;
	context->sockfd_hsm = -1;
	struct sockaddr_in cli_addr;
    /*--------------------------------------------------------*/
    /* Initialize the socket address structure                */
    /*--------------------------------------------------------*/
    memset(&cli_addr, 0x00, sizeof(cli_addr));
    cli_addr.sin_family      = AF_INET;
    cli_addr.sin_port        = htons(INPUT->brd_connt_port_no);
    cli_addr.sin_addr.s_addr = inet_addr(INPUT->tmn_ip);

    /*--------------------------------------------------------*/
    /* Create an AF_INET stream socket                        */
    /*--------------------------------------------------------*/
    context->sockfd_hsm = socket(AF_INET, SOCK_STREAM, 0);
    if (context->sockfd_hsm < 0){
		LOGGER(LOG_ERROR,  "init client Socket to HSM ERROR [%d]", errno);		
		return ABNORMAL;
    } 
	int sockfd_flags_before;
	if( ( sockfd_flags_before=fcntl(context->sockfd_hsm, F_GETFL,0) ) < 0 ) return ABNORMAL;
	if( fcntl( context->sockfd_hsm, F_SETFL, sockfd_flags_before | O_NONBLOCK ) < 0 ) return ABNORMAL;
	
	// Start connection asyncronously
	do{
		if(connect(context->sockfd_hsm,(struct sockaddr *)&cli_addr,sizeof(cli_addr)) < 0)
        {
            //Did connection return an error? If so , we'll fail
            if( (errno != EWOULDBLOCK) && (errno != EINPROGRESS) ){
            	rc = -1;
            }else{
				struct timespec now;	
				if(clock_gettime(CLOCK_MONOTONIC, &now) < 0 ){
					rc = -1; 
					break;
				}         
				struct timespec deadline = {
						.tv_sec = now.tv_sec ,
						.tv_nsec = now.tv_nsec + timeout_ms*1000000l}; 
				do{
					if(clock_gettime(CLOCK_MONOTONIC, &now) < 0 ){
						rc = -1; 
						break;
					}  
					// Calculate how long until deadline
					int ms_until_deadline = (int)( (deadline.tv_sec - now.tv_sec)*1000l + 
												   (deadline.tv_nsec - now.tv_nsec)/1000000l);
					if(ms_until_deadline < 0){
						rc = 0;
						break;
					}
					// Wait for connect to complete( or for the timeout deadline )
					struct pollfd pfds[] = { {.fd = context->sockfd_hsm, .events = POLLOUT} };
					rc = poll(pfds, 1, ms_until_deadline);
					// If poll secceeded , make sure it really succeeded
					if(rc > 0){  
						int error = 0; 
						socklen_t len = sizeof(error);
						int reval = getsockopt(context->sockfd_hsm, SOL_SOCKET, SO_ERROR, &error, &len);
						if(reval == 0 ) errno = error;
						if( error  != 0 ){ 
							rc = -1;
							LOGGER(LOG_ERROR,  "Connection Failed", "");	
						}
					}
				}
				// If poll was interrupted , tru again.
				while( rc ==-1 && errno==EINTR );	
				// Did poll timeout? If so , fail.
				if(rc == 0){
					errno = ETIMEDOUT;
					LOGGER(LOG_ERROR,  "Connection Timeout", "");	
					rc = -1;
				}
            }
        }
	}while(0);
	if( fcntl(context->sockfd_hsm, F_SETFL, sockfd_flags_before) < 0 ) return ABNORMAL;
	return (rc < 0 ? ABNORMAL : NORMAL ); 
}
static int writeUnixSocket(sockfd, senddata, sendlen)
int  sockfd;
char *senddata;
int  sendlen;
{
    register int nleft, nwritten;

    nleft = sendlen;
    while (nleft > 0)  
    {
        nwritten = write(sockfd, senddata, nleft);
		LOGGER(LOG_DEBUG,  "Write data [%d - %d",nwritten,sendlen);
        if (nwritten < 0)
        {
            if (errno == EINTR) continue;   
            return (nwritten);
        }
        else if (nwritten == 0) break;

        nleft -= nwritten;
        senddata += nwritten;
    }

    return (sendlen - nleft);
}

static int readUnixSocket(sockfd, recvdata, recvlen)
int  sockfd;
char *recvdata;
int  recvlen;
{ 
    register int nleft, nreadlen, willreadlen;
    char tmp[DEFPACKETSIZE];

    nleft = recvlen;
    willreadlen = recvlen;
    while (nleft > 0)
    {
        if (nleft > sizeof(tmp)) willreadlen = sizeof(tmp);
        else                     willreadlen = nleft;
        memset(tmp, 0x00, sizeof(tmp));
        nreadlen = read(sockfd, tmp, willreadlen);
        if (nreadlen <  0)
        {
            if (errno == EINTR) continue;
            return (nreadlen);
        }
        else if (nreadlen == 0) return (nreadlen);

        nleft -= nreadlen;
        memcpy(recvdata, tmp, nreadlen);   
        recvdata += nreadlen;   
    }

    return (recvlen - nleft);      
}
static int writeHsmSocket(hsmManagementContext *context)
{   
	char s_buf[1024 + 1] = {0x00, };  
	if( strncmp( INPUT->rqst_svc_c, HSM_SND_ID_SMTIFD, 6 ) == 0 ){
		LOGGER(LOG_INFO, "Socket SND_MSG [%s - %d] ",context->hsm_sendBuffer + 2, context->hsm_sndMsgLen);
		if (writeSocket(context->sockfd_hsm, context->hsm_sendBuffer, context->hsm_sndMsgLen) <= 0 ){
			LOGGER(LOG_ERROR, "send data to Socket HSM FAIL ", "");
			return ABNORMAL;
		}     
	}else{   
		LOGGER(LOG_INFO, "IPC SND_MSG [%s - %d] ",context->hsm_sendBuffer + 2, context->hsm_sndMsgLen);
		if (writeUnixSocket(context->sockfd_hsm, context->hsm_sendBuffer, context->hsm_sndMsgLen) <= 0 ){
			LOGGER(LOG_ERROR, "send data to IPC HSM FAIL ", "");
			return ABNORMAL;
		}
	}
  
}

static int readHsmSocket(hsmManagementContext *context) 
{
	int iret = 0;
	if( strncmp( INPUT->rqst_svc_c, HSM_SND_ID_SMTIFD, 6 ) == 0 ){
		if ((iret = readSocket(context->sockfd_hsm, context->hsm_recvBuffer, context->hsm_rcvMsgLen)) <= 0 ){
			LOGGER(LOG_ERROR, "Read data from Socket HSM FAIL", "");
			return ABNORMAL;
		}
	}else{
		if ( ( iret = readUnixSocket(context->sockfd_hsm, context->hsm_recvBuffer, context->hsm_rcvMsgLen)) <= 0 ){
			LOGGER(LOG_ERROR, "Read data from IPC HSM FAIL", "");
			return ABNORMAL;
		}
	}
	return iret;
}
/*----------------------------------------------------------------------------  	*/
/* SUBJECT  : Connect to HSM		                                              	*/
/* ARGUMENT :                                                                   	*/
/*  sndId :                                                                     	*/
/*      smtifd : diretly via TCP                                              		*/
/*      amtifp : via PipeLine  inter-socket                                     	*/
/*  sockfd_hsm : hsm socket ID                                                  	*/
/* RETURN   : SUCCESS: NORMAL                                                   	*/
/*----------------------------------------------------------------------------		*/

static long connectToHSM(hsmManagementContext *context)
{  
	if (context->sockfd_hsm > 0){
    	close(context->sockfd_hsm);
    	context->sockfd_hsm = -1;
    }
    
	if( strncmp( INPUT->rqst_svc_c, HSM_SND_ID_SMTIFD, 6 ) == 0 ){

		LOGGER(LOG_INFO,  "HSM SERVER CONNECT TRYING...[%s:%d]",INPUT->tmn_ip, INPUT->brd_connt_port_no);	
		if(initSocket(context,2000) != NORMAL){
			LOGGER(LOG_ERROR,  "Connect Net Socket to HSM ERROR....[%s:%d]",INPUT->tmn_ip, INPUT->brd_connt_port_no);	
			return ABNORMAL;
		}
		
    }else{   
		if(initClientUnixSocket(context, 2000) != NORMAL){
			if(initSocket(context,2000) != NORMAL){
				LOGGER(LOG_ERROR,  "Re-try Connect Net Socket to HSM ERROR....[%s:%d]",INPUT->tmn_ip, INPUT->brd_connt_port_no);	
				return ABNORMAL;
			}
		}else{
			LOGGER(LOG_INFO,  "Connected IPC to HSM [%s]",INPUT->rqst_svc_c);	
		}
	}
	if (context->sockfd_hsm < 0)
	{
		LOGGER(LOG_ERROR,  "Connect to HSM ERROR", "");
		return ABNORMAL;
	}

    return NORMAL;  
}
/*----------------------------------------------------------------------------*/
/* Send Message To HSM                                                        */
/*   																		  */
/*----------------------------------------------------------------------------*/
static long sendDataToHSM(hsmManagementContext *context)
{
	if(connectToHSM(context) != NORMAL){
		return ABNORMAL;
	}
	if (writeHsmSocket(context) <= 0 ){
		LOGGER(LOG_ERROR,  "send data to HSM FAIL", "");
		return ABNORMAL;
	}
		
	LOGGER(LOG_INFO,  "send data to HSM Successfully", "");	
	return NORMAL;
}

/*----------------------------------------------------------------------------*/
/* Receive Message From HSM                                                   */
/*   																		  */
/*----------------------------------------------------------------------------*/
static long rcvDataFromHSM(hsmManagementContext *context)
{
	int iret = 0;
	uint64_t r_length;
	fd_set rset;
	struct timeval tval;

	tval.tv_sec  = 5;
    tval.tv_usec = 0;   

	int read_flag = 0;  
	FD_ZERO(&rset);

	if(context->sockfd_hsm != -1)
		FD_SET(context->sockfd_hsm, &rset);

	int maxfd = context->sockfd_hsm;

	int ret = select(maxfd+1, &rset, 0, 0, &tval);
	if (ret == -1)
	{
		LOGGER(LOG_ERROR,  "get TCP Socket Trx event Error", "");
		return ABNORMAL;
	}
	else if (ret == 0)
	{
		LOGGER(LOG_ERROR,  "Reach TCP Socket Trx event Timeout %d seconds", tval.tv_sec);
		return ABNORMAL;
	}
	else
	{
		if(FD_ISSET(context->sockfd_hsm, &rset))	read_flag = 1;
		else read_flag = 0;
	}
	
	if (read_flag > 0)
	{
		LOGGER(LOG_DEBUG,  "Start Read", "");
		context->hsm_rcvMsgLen = 2;
		if (readHsmSocket(context) <= 0)
		{
			LOGGER(LOG_ERROR,  "readSocket 1  [sockfd=%d recvLength=%d ERROR 1", context->sockfd_hsm, iret);
			return  ABNORMAL;
		}
		context->hsm_rcvMsgLen = (long)( (context->hsm_recvBuffer[0] * 256)&0xFF) + (long)(context->hsm_recvBuffer[1]&0xFF);
		memset(context->hsm_recvBuffer, 0x00, sizeof(context->hsm_recvBuffer))	;  
		if (readHsmSocket(context) <= 0)
		{
			LOGGER(LOG_ERROR,  "readSocket 1  [sockfd=%d recvLength=%d ERROR 2", context->sockfd_hsm, iret);
			return  ABNORMAL;
		}
	} 
	if (context->sockfd_hsm > 0){
		close(context->sockfd_hsm);
		context->sockfd_hsm = -1;  
	}
	LOGGER(LOG_DEBUG,  "hsm_recvBuffer [%s]", context->hsm_recvBuffer);
	return NORMAL;
}

static long execCmd(hsmManagementContext *context)   
{
	if(sendDataToHSM(context) != NORMAL){
		return ABNORMAL;
	}
	if(rcvDataFromHSM(context) != NORMAL){
		return ABNORMAL;
	}
	return NORMAL;
}

int importZpkKey(hsmManagementContext *context )
{
	memset(&context->r_code, 0x00, sizeof(context->r_code));
	memset(&context->r_data, 0x00, sizeof(context->r_data));
	memset(&context->hsm_sendBuffer, 0x00, sizeof(context->hsm_sendBuffer));
	memset(&context->hsm_recvBuffer, 0x00, sizeof(context->hsm_recvBuffer));
	
	int s_length = 0;
	char return_val[1024] = {0x00,};
	
	char l_zmk[200 + 1] = {0x00, };
	sprintf(l_zmk, "%s", INPUT->zmk_ctt);
	char l_zpk[200 + 1] = {0x00, };
	sprintf(l_zpk, "%s", INPUT->src_zpk_ctt);  
	
	memset(s_cmdA6.msghead, 0x20, sizeof(s_cmdA6.msghead) );
	memcpy(s_cmdA6.msghead, "1234", 4);
	memset(s_cmdA6.cmdcode, 0x20, sizeof(s_cmdA6.cmdcode) );
	memcpy(s_cmdA6.cmdcode, "A6", 2);
	memset(s_cmdA6.keytype, 0x20, sizeof(s_cmdA6.keytype) );
	memcpy(s_cmdA6.keytype, "FFF", 3); 
	memset(s_cmdA6.zmk, 0x20, sizeof(s_cmdA6.zmk) );
	memcpy(s_cmdA6.zmk, l_zmk, strlen(l_zmk)); 
	memset(s_cmdA6.dstblockkey, 0x20, sizeof(s_cmdA6.dstblockkey) );
	memcpy(s_cmdA6.dstblockkey, l_zpk, strlen(l_zpk)); 
	memset(s_cmdA6.kschem, 0x20, sizeof(s_cmdA6.kschem) );
	memcpy(s_cmdA6.kschem, "S", 1); 
	memset(s_cmdA6.deli, 0x20, sizeof(s_cmdA6.deli) );        
	memset(s_cmdA6.lmkiden, 0x20, sizeof(s_cmdA6.lmkiden) );    
	
	if(strlen(INPUT->lmk_id) > 0){    
		memcpy(s_cmdA6.deli, "%", 1);
		memcpy(s_cmdA6.lmkiden, INPUT->lmk_id, 2); 
	}
	
	context->hsm_sndMsgLen = 0;
	context->hsm_rcvMsgLen = 0;
	memset(return_val, 0x20, sizeof(return_val) - 1);

	memcpy(return_val, &s_cmdA6, sizeof(s_cmdA6) );   
	removeSpace(return_val, &context->hsm_sendBuffer[2]);
	
	     
	s_length = strlen(&context->hsm_sendBuffer[2]); 
	context->hsm_sendBuffer[0] = s_length / 256;
	context->hsm_sendBuffer[1] = s_length % 256;
	context->hsm_sndMsgLen = 2 + s_length;
	  
	if(execCmd(context) != NORMAL){
		return ABNORMAL;
	}
	
	if(checkResp(context, "A7") != NORMAL){
		LOGGER(LOG_ERROR,   "respcode code is not correct [A7 - %.*s] ", 2, context->hsm_recvBuffer + 4);
		return ABNORMAL;
	}

	memcpy(OUTPUT->atm_respond_c, context->hsm_recvBuffer + 6, sizeof(OUTPUT->atm_respond_c) -1);
	if(strncmp(OUTPUT->atm_respond_c, "00", 2 ) == 0){
		char keylen[5] = {0x00,};
		long keySrtIdx = 8,keyUnderLmkLen = 0, keyUnderZmkLen = 0;
		sprintf(keylen, "%.4s", context->hsm_recvBuffer + keySrtIdx + 1 + 1);     
		keyUnderLmkLen = atoi(keylen);
		memcpy(OUTPUT->dest_zpk_ctt, context->hsm_recvBuffer + keySrtIdx, keyUnderLmkLen + 1);
		keySrtIdx+=keyUnderLmkLen + 1;  
		memcpy(OUTPUT->mac_ctt, context->hsm_recvBuffer + keySrtIdx, 6);
	}
	return NORMAL;
}

