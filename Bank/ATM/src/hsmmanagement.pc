int encPinUnderLmk(hsmManagementContext *context )
{
	bzero(&context->r_code, sizeof(context->r_code));
	bzero(&context->r_data, sizeof(context->r_data));
	bzero(&context->hsm_sendBuffer, sizeof(context->hsm_sendBuffer));
	bzero(&context->hsm_recvBuffer, sizeof(context->hsm_recvBuffer));
	
	int s_length = 0;
	char return_val[1024] = {0x00,};
	
	char pinblock[13 + 1] = {0x00,};  
	memset(pinblock, 'F', sizeof(pinblock) -1 );
	int pin_len = strlen(INPUT->atm_psn_pin_nw) > 13 ? 13 : strlen(INPUT->atm_psn_pin_nw);
	memcpy(pinblock, INPUT->atm_psn_pin_nw, pin_len);
	
	char l_pan[12 + 1] = {0x00, };
	snprintf(l_pan,sizeof(l_pan), "%.12s", INPUT->atm_pan_ctt + (strlen(INPUT->atm_pan_ctt) -12 ) );  // 12 right-most digits 
	
	memset(s_cmdBA.msghead, 0x20, sizeof(s_cmdBA.msghead) );
	memcpy(s_cmdBA.msghead, "1234", 4);
	memset(s_cmdBA.cmdcode, 0x20, sizeof(s_cmdBA.cmdcode) );
	memcpy(s_cmdBA.cmdcode, "BA", 2);
	memset(s_cmdBA.pin, 0x20, sizeof(s_cmdBA.pin) );
	memcpy(s_cmdBA.pin, pinblock, 13);
	memset(s_cmdBA.pan, 0x20, sizeof(s_cmdBA.pan) );
	memcpy(s_cmdBA.pan, l_pan, 12);
	memset(s_cmdBA.lmkdeli, 0x20, sizeof(s_cmdBA.lmkdeli) );
	memset(s_cmdBA.lmkiden, 0x20, sizeof(s_cmdBA.lmkiden) );
	
	if(strlen(INPUT->lmk_id) > 0 ){
		memcpy(s_cmdBA.lmkdeli, "%", 1);
		memcpy(s_cmdBA.lmkiden, INPUT->lmk_id, 2); 
	}
	
	context->hsm_sndMsgLen = 0;
	context->hsm_rcvMsgLen = 0;
	memset(return_val, 0x20, sizeof(return_val) - 1);

	memcpy(return_val, &s_cmdBA, sizeof(s_cmdBA) );
	removeSpace(return_val, &context->hsm_sendBuffer[2]);
	
	
	s_length = strlen(&context->hsm_sendBuffer[2]);  
	context->hsm_sendBuffer[0] = s_length / 256;
	context->hsm_sendBuffer[1] = s_length % 256;
	
	context->hsm_sndMsgLen = 2 + s_length;
	
	if(execCmd(context) != NORMAL){
		return ABNORMAL;
	}
	
	if(checkResp(context, "BB") != NORMAL){
		LOGGER(LOG_ERROR,   "respcode code is not correct [BB - %.*s] ", 2, context->hsm_recvBuffer + 4);
		return ABNORMAL;
	}
	
	return NORMAL;
}       

int translatePinLmkToZpk(hsmManagementContext *context)
{   
	bzero(&context->r_code, sizeof(context->r_code));
	bzero(&context->r_data, sizeof(context->r_data));
	bzero(&context->hsm_sendBuffer, sizeof(context->hsm_sendBuffer));
	bzero(&context->hsm_recvBuffer, sizeof(context->hsm_recvBuffer));
	
	int s_length = 0;
	char return_val[1024] = {0x00,};
	    
	char l_dzpk[200 + 1] = {0x00, };
	snprintf(l_dzpk, sizeof(l_dzpk), "%s", INPUT->dest_zpk_ctt);
	memset(s_cmdJG.msghead, 0x20, sizeof(s_cmdJG.msghead) );
	memcpy(s_cmdJG.msghead, "1234", 4);
	memset(s_cmdJG.cmdcode, 0x20, sizeof(s_cmdJG.cmdcode) );
	memcpy(s_cmdJG.cmdcode, "JG", 2);
	memset(s_cmdJG.deszpk, 0x20, sizeof(s_cmdJG.deszpk) );
	memcpy(s_cmdJG.deszpk, l_dzpk, strlen(l_dzpk));
	memset(s_cmdJG.pinform, 0x20, sizeof(s_cmdJG.pinform) );
	memcpy(s_cmdJG.pinform, "48", 2);
	memset(s_cmdJG.pan, 0x20, sizeof(s_cmdJG.pan) );
	memcpy(s_cmdJG.pan, INPUT->atm_pan_ctt , strlen(INPUT->atm_pan_ctt));
	memset(s_cmdJG.pindeli, 0x20, sizeof(s_cmdJG.pindeli) );
	memcpy(s_cmdJG.pindeli, ";", 1);
	memset(s_cmdJG.encpin, 0x20, sizeof(s_cmdJG.encpin) );
	memcpy(s_cmdJG.encpin, INPUT->atm_psn_pin_nw, 33);
	memset(s_cmdJG.lmkdeli, 0x20, sizeof(s_cmdJG.lmkdeli) );
	memset(s_cmdJG.lmkiden, 0x20, sizeof(s_cmdJG.lmkiden) );
	
	if(strlen(INPUT->lmk_id) > 0 ){
		memcpy(s_cmdJG.lmkdeli, "%", 1);
		memcpy(s_cmdJG.lmkiden, INPUT->lmk_id, 2); 
	}
	
	context->hsm_sndMsgLen = 0;
	context->hsm_rcvMsgLen = 0;

	memcpy(return_val, &s_cmdJG, sizeof(s_cmdJG) );
	removeSpace(return_val, &context->hsm_sendBuffer[2]);
	
	s_length = strlen(&context->hsm_sendBuffer[2]);  
	context->hsm_sendBuffer[0] = s_length / 256;
	context->hsm_sendBuffer[1] = s_length % 256;
	context->hsm_sndMsgLen = 2 + s_length;
	
	if(execCmd(context) != NORMAL){
		return ABNORMAL;
	}
	
	if(checkResp(context, "JH") != NORMAL){
		LOGGER(LOG_ERROR,   "respcode code is not correct [JH - %.*s] ", 2, context->hsm_recvBuffer + 4);
		return ABNORMAL;
	}
	return NORMAL;
}

int translatePinZpkToLmk(hsmManagementContext *context)   
{
	memset(context->r_code, 0x00, sizeof(context->r_code));
	memset(context->r_data, 0x00, sizeof(context->r_data));
	memset(context->hsm_recvBuffer, 0x00, sizeof(context->hsm_recvBuffer));
	memset(context->hsm_sendBuffer, 0x00, sizeof(context->hsm_sendBuffer));
	char l_pan[12 + 1] = {0x00, };
	snprintf(l_pan, sizeof(l_pan), "%.12s", INPUT->atm_pan_ctt + (strlen(INPUT->atm_pan_ctt) -12 -1 ) );  // 12 right-most digits , exclude check digit
 
	int s_length = 0;
	char return_val[1024] = {0x00,};    
	char l_dzpk[200 + 1] = {0x00, };
	snprintf(l_dzpk, sizeof(l_dzpk), "%s", INPUT->dest_zpk_ctt);  

	// memset(s_cmdM6, 0x00, sizeof(s_cmdM6) );
	memset(s_cmdJE.msghead, 0x20, sizeof(s_cmdJE.msghead) );
	memcpy(s_cmdJE.msghead, "1234", 4);
	memset(s_cmdJE.cmdcode, 0x20, sizeof(s_cmdJE.cmdcode) );   
	memcpy(s_cmdJE.cmdcode, "JE", 2);   
	memset(s_cmdJE.deszpk, 0x20, sizeof(s_cmdJE.deszpk) );
	memcpy(s_cmdJE.deszpk, l_dzpk, strlen(l_dzpk));
	memset(s_cmdJE.pinblock, 0x20, sizeof(s_cmdJE.pinblock) );    
	memcpy(s_cmdJE.pinblock, INPUT->atm_psn_pin_nw, 32);
	memset(s_cmdJE.pinform, 0x20, sizeof(s_cmdJE.pinform) );  
	memcpy(s_cmdJE.pinform, "48", 2);
	memset(s_cmdJE.pan, 0x20, sizeof(s_cmdJE.pan) );
	// memcpy(s_cmdJE.pan, INPUT->atm_pan_ctt, strlen(INPUT->atm_pan_ctt) -1 );
	memcpy(s_cmdJE.pan, l_pan, 12 );
	memset(s_cmdJE.pindeli, 0x20, sizeof(s_cmdJE.pindeli) );
	memcpy(s_cmdJE.pindeli, ";", 1);
	memset(s_cmdJE.lmkdeli, 0x20, sizeof(s_cmdJE.lmkdeli) );
	memset(s_cmdJE.lmkiden, 0x20, sizeof(s_cmdJE.lmkiden) );
	
	if(strlen(INPUT->lmk_id) > 0 ){
		memcpy(s_cmdJE.lmkdeli, "%", 1);  
		memcpy(s_cmdJE.lmkiden, INPUT->lmk_id, 2); 
	}
   
	context->hsm_sndMsgLen = 0;
	context->hsm_rcvMsgLen = 0;
	memset(return_val, 0x20, sizeof(return_val) - 1);  

	memcpy(return_val, &s_cmdJE, sizeof(s_cmdJE) );
	removeSpace(return_val, &context->hsm_sendBuffer[2]);
	
	s_length = strlen(&context->hsm_sendBuffer[2]);     
	context->hsm_sendBuffer[0] = s_length / 256;    
	context->hsm_sendBuffer[1] = s_length % 256;
	context->hsm_sndMsgLen = 2 + s_length;
	if(execCmd(context) != NORMAL){
		return ABNORMAL;
	}
	if(checkResp(context, "JF") != NORMAL){
		LOGGER(LOG_ERROR,   "respcode code is not correct [JF - %.*s] ", 2, context->hsm_recvBuffer + 4);
		return ABNORMAL;
	}
	return NORMAL;
}

int translatePinZpkToLmkNAP(hsmManagementContext *context)   
{
	memset(context->r_code, 0x00, sizeof(context->r_code));
	memset(context->r_data, 0x00, sizeof(context->r_data));
	memset(context->hsm_recvBuffer, 0x00, sizeof(context->hsm_recvBuffer));
	memset(context->hsm_sendBuffer, 0x00, sizeof(context->hsm_sendBuffer));
	// char l_pan[12 + 1] = {0x00, };
	// snprintf(l_pan, sizeof(l_pan), "%.12s", INPUT->atm_pan_ctt + (strlen(INPUT->atm_pan_ctt) -12 -1 ) );  // 12 right-most digits , exclude check digit
 
	int s_length = 0;
	char return_val[1024] = {0x00,};    
	char l_dzpk[256 + 1] = {0x00, };
	snprintf(l_dzpk, sizeof(l_dzpk), "%s", INPUT->dest_zpk_ctt);  

	// memset(s_cmdM6, 0x00, sizeof(s_cmdM6) );
	memset(s_cmdJE.msghead, 0x20, sizeof(s_cmdJE.msghead) );
	memcpy(s_cmdJE.msghead, "1234", 4);
	memset(s_cmdJE.cmdcode, 0x20, sizeof(s_cmdJE.cmdcode) );   
	memcpy(s_cmdJE.cmdcode, "JE", 2);   
	memset(s_cmdJE.deszpk, 0x20, sizeof(s_cmdJE.deszpk) );
	memcpy(s_cmdJE.deszpk, l_dzpk, strlen(l_dzpk));
	memset(s_cmdJE.pinblock, 0x20, sizeof(s_cmdJE.pinblock) );    
	memcpy(s_cmdJE.pinblock, INPUT->atm_psn_pin_nw, 32);
	memset(s_cmdJE.pinform, 0x20, sizeof(s_cmdJE.pinform) );  
	memcpy(s_cmdJE.pinform, "48", 2);
	memset(s_cmdJE.pan, 0x20, sizeof(s_cmdJE.pan) );
	// memcpy(s_cmdJE.pan, INPUT->atm_pan_ctt, strlen(INPUT->atm_pan_ctt) -1 );
	memcpy(s_cmdJE.pan, INPUT->atm_pan_ctt, strlen(INPUT->atm_pan_ctt) );
	memset(s_cmdJE.pindeli, 0x20, sizeof(s_cmdJE.pindeli) );
	memcpy(s_cmdJE.pindeli, ";", 1);
	memset(s_cmdJE.lmkdeli, 0x20, sizeof(s_cmdJE.lmkdeli) );
	memset(s_cmdJE.lmkiden, 0x20, sizeof(s_cmdJE.lmkiden) );
	
	if(strlen(INPUT->lmk_id) > 0 ){
		memcpy(s_cmdJE.lmkdeli, "%", 1);  
		memcpy(s_cmdJE.lmkiden, INPUT->lmk_id, 2); 
	}
   
	context->hsm_sndMsgLen = 0;
	context->hsm_rcvMsgLen = 0;  
	memset(return_val, 0x20, sizeof(return_val) - 1);  

	memcpy(return_val, &s_cmdJE, sizeof(s_cmdJE) );
	removeSpace(return_val, &context->hsm_sendBuffer[2]);
	
	s_length = strlen(&context->hsm_sendBuffer[2]);     
	context->hsm_sendBuffer[0] = s_length / 256;    
	context->hsm_sendBuffer[1] = s_length % 256;
	context->hsm_sndMsgLen = 2 + s_length;
	if(execCmd(context) != NORMAL){
		return ABNORMAL;
	}
	if(checkResp(context, "JF") != NORMAL){
		LOGGER(LOG_ERROR,   "respcode code is not correct [JF - %.*s] ", 2, context->hsm_recvBuffer + 4);
		return ABNORMAL;
	}
	return NORMAL;
}

int decryptPINByLmk(hsmManagementContext *context)    
{
	memset(context->r_code, 0x00, sizeof(context->r_code));
	memset(context->r_data, 0x00, sizeof(context->r_data));
	memset(context->hsm_recvBuffer, 0x00, sizeof(context->hsm_recvBuffer));
	memset(context->hsm_sendBuffer, 0x00, sizeof(context->hsm_sendBuffer));
	int s_length = 0;
