	memcpy(s_cmdNG.cmdcode, "NG", 2);
	memset(s_cmdNG.encpin, 0x20, sizeof(s_cmdNG.encpin) );
	memcpy(s_cmdNG.encpin, INPUT->atm_psn_pin_nw, 33);
	memset(s_cmdNG.pan, 0x20, sizeof(s_cmdNG.pan) );
	memcpy(s_cmdNG.pan, l_pan, 12);
	memset(s_cmdNG.lmkdeli, 0x20, sizeof(s_cmdNG.lmkdeli) );
	memset(s_cmdNG.lmkiden, 0x20, sizeof(s_cmdNG.lmkiden) );  
	
	if(strlen(INPUT->lmk_id) > 0){
		memcpy(s_cmdNG.lmkdeli, "%", 1);
		memcpy(s_cmdNG.lmkiden, INPUT->lmk_id, 2); 
	}

	context->hsm_sndMsgLen = 0;
	context->hsm_rcvMsgLen = 0;
	memset(return_val, 0x20, sizeof(return_val) - 1);

	memcpy(return_val, &s_cmdNG, sizeof(s_cmdNG) );
	removeSpace(return_val, &context->hsm_sendBuffer[2]);
	// rtrimString(return_val);
	s_length = strlen(&context->hsm_sendBuffer[2]);     
	context->hsm_sendBuffer[0] = s_length / 256;
	context->hsm_sendBuffer[1] = s_length % 256;
	// memcpy(&context->hsm_sendBuffer[2], return_val, s_length);
	context->hsm_sndMsgLen = 2 + s_length;

	if(execCmd(context) != NORMAL){
		return ABNORMAL;
	}
	
	if(checkResp(context, "NH") != NORMAL){
		LOGGER(LOG_ERROR,   "respcode code is not correct [NH - %.*s] ", 2, context->hsm_recvBuffer + 4);
		return ABNORMAL;
	}

	return NORMAL;
}

