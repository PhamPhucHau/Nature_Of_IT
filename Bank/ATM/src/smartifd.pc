/* ???º??? : ???? : NORMAL                                                   */
/*----------------------------------------------------------------------------*/
int insertToSWSNAPRCV(char* napas_data, char* sdata)
{
    char c_trx_brno             [ 4 + 1] = {0x00, };
    char c_atm_trx_tmn_no       [ 4 + 1] = {0x00, };
    char c_atm_trx_trace_no     [ 6 + 1] = {0x00, };
    char c_atm_trx_amt          [12 + 1] = {0x00, };
    char c_atm_acpn_man_rcgn_c  [11 + 1] = {0x00, };
    char c_stmt_amt             [12 + 1] = {0x00, };
    char c_claim_amt            [12 + 1] = {0x00, };
    char c_stmt_exrt            [ 8 + 1] = {0x00, };
    char c_claim_exrt           [ 8 + 1] = {0x00, };
    char c_atm_dspch_org_rcgn_c [11 + 1] = {0x00, };
    char c_nap_data             [500+ 1] = {0x00, };

EXEC SQL BEGIN DECLARE SECTION;
    int  trx_brno               = 0;
    int  atm_trx_trace_no       = 0;
    int  atm_trx_tmn_no         = 0;
    char napas_proc_id          [ 3 + 1] = {0x00, };
    // char glb_id                 [30 + 1] = {0x00, };
    char glb_id                 [32 + 1] = {0x00, };
    char atm_msg_t_id           [ 4 + 1] = {0x00, };
    char atm_trx_c              [ 6 + 1] = {0x00, };
    char proc_name              [ 8 + 1] = {0x00, };
    char atm_pan_ctt            [19 + 1] = {0x00, };
    int  atm_trx_amt            = 0;
    char atm_forwd_dttm         [14 + 1] = {0x00, };
    char atm_acpn_org_rcgn_c    [11 + 1] = {0x00, };
    char trx_ccy_c              [ 3 + 1] = {0x00, };
    char atm_ntw_mng_inf_ctt    [ 3 + 1] = {0x00, };
    char atm_orgtrx_data_ctt    [42 + 1] = {0x00, };
    char atm_wthd_ac_rcgn_no    [28 + 1] = {0x00, };
    char atm_rcpt_ac_rcgn_no    [28 + 1] = {0x00, };
    int  atm_acpn_man_rcgn_c    = 0;
    int  stmt_amt               = 0;
    int  claim_amt              = 0;
    int  stmt_exrt              = 0;
    int  claim_exrt             = 0;
    char stmt_ccy_c             [ 3 + 1] = {0x00, };
    char claim_ccy_c            [ 3 + 1] = {0x00, };
    char atm_mdm_d              [ 2 + 1] = {0x00, };
    char otr_srch_refno         [12 + 1] = {0x00, };
    char otr_respond_c          [ 2 + 1] = {0x00, };
    int  atm_dspch_org_rcgn_c   = 0;
    char atm_napas_trx_refno    [16 + 1] = {0x00, };
    char atm_otrnt_d            [ 2 + 1] = {0x00, };
    char swc_svr_d              [ 1 + 1] = {0x00, };
    char nap_data               [ 500+1] = {0x00, };
    char c_trdat                [4000+1] = {0x00, };
EXEC SQL END DECLARE SECTION;

	LOGGER(LOG_DEBUG,"Start... ", "");

	if (is_ibt == 0)
    	memcpy(napas_proc_id, "ETC", sizeof(napas_proc_id) - 1);
	if (is_ibt == 1 || is_ibt == 2) //LKMT 2022.03.07 add is_ibt = 2
    	memcpy(napas_proc_id, "IBT", sizeof(napas_proc_id) - 1);

    sprintf(c_nap_data, "%.*s", sizeof(c_nap_data), napas_data);
    rtrimString(c_nap_data);
    memcpy(nap_data, c_nap_data, sizeof(nap_data) -1 );

    memcpy(c_trx_brno, ChnlHead.trxbrno, sizeof(c_trx_brno) -1);
    trx_brno = atoi(c_trx_brno);
    memcpy(c_atm_trx_tmn_no, ChnlHead.trx_trmno, sizeof(c_atm_trx_tmn_no) -1);
    atm_trx_tmn_no = atoi(c_atm_trx_tmn_no);
    memcpy(c_atm_trx_trace_no, MsgData.bit_11, sizeof(c_atm_trx_trace_no) -1);
    atm_trx_trace_no = atoi(c_atm_trx_trace_no);
    // memcpy(glb_id, MsgHead.glob_id, sizeof(glb_id) -1);
    sprintf(glb_id, "%.*s%.*s", sizeof(MsgHead.glob_id), MsgHead.glob_id, sizeof(MsgHead.step), MsgHead.step);
    memcpy(atm_msg_t_id, MsgData.msgtype, sizeof(atm_msg_t_id) -1);
    memcpy(atm_trx_c, MsgData.bit_3, sizeof(atm_trx_c) -1);
    memcpy(proc_name, exeName, sizeof(proc_name) -1);
    memcpy(atm_pan_ctt, MsgData.bit_2, sizeof(atm_pan_ctt) -1);
    memcpy(c_atm_trx_amt, MsgData.bit_4, sizeof(c_atm_trx_amt) -1);
    atm_trx_amt = atoi(c_atm_trx_amt);
    memcpy(atm_forwd_dttm, MsgData.bit_7, sizeof(atm_forwd_dttm) -1);
    memcpy(atm_acpn_org_rcgn_c, MsgData.bit_32, sizeof(atm_acpn_org_rcgn_c) -1);
    memcpy(trx_ccy_c, MsgData.bit_49, sizeof(trx_ccy_c) -1);
    memcpy(atm_ntw_mng_inf_ctt, MsgData.bit_70, sizeof(atm_ntw_mng_inf_ctt) -1);
    memcpy(atm_orgtrx_data_ctt, MsgData.bit_90, sizeof(atm_orgtrx_data_ctt) -1);
    memcpy(atm_wthd_ac_rcgn_no, MsgData.bit_102, sizeof(atm_wthd_ac_rcgn_no) -1);
    memcpy(atm_rcpt_ac_rcgn_no, MsgData.bit_103, sizeof(atm_rcpt_ac_rcgn_no) -1);
    memcpy(c_atm_acpn_man_rcgn_c, MsgData.bit_100, sizeof(c_atm_acpn_man_rcgn_c) -1);
    atm_acpn_man_rcgn_c = atoi(c_atm_acpn_man_rcgn_c);
    memcpy(c_stmt_amt, &MsgData.atm_ord_ctt[910], sizeof(c_stmt_amt) -1);
    stmt_amt = atoi(c_stmt_amt);
    memcpy(c_claim_amt, &MsgData.atm_ord_ctt[922], sizeof(c_claim_amt) -1);
    claim_amt = atoi(c_claim_amt);
    memcpy(c_stmt_exrt, &MsgData.atm_ord_ctt[934], sizeof(c_stmt_exrt) -1);
    stmt_exrt = atoi(c_stmt_exrt);
    memcpy(c_claim_exrt, &MsgData.atm_ord_ctt[942], sizeof(c_claim_exrt) -1);
    claim_exrt = atoi(c_claim_exrt);
    memcpy(stmt_ccy_c, &MsgData.atm_ord_ctt[950], sizeof(stmt_ccy_c) -1);
    memcpy(claim_ccy_c, &MsgData.atm_ord_ctt[953], sizeof(claim_ccy_c) -1);
    memcpy(atm_mdm_d, MsgData.atm_mdm_d, sizeof(atm_mdm_d) -1);
    memcpy(otr_srch_refno, MsgData.bit_37, sizeof(otr_srch_refno) -1);
    memcpy(otr_respond_c, MsgData.bit_39, sizeof(otr_respond_c) -1);
    memcpy(c_atm_dspch_org_rcgn_c, MsgData.bit_33, sizeof(c_atm_dspch_org_rcgn_c) -1);
    atm_dspch_org_rcgn_c = atoi(c_atm_dspch_org_rcgn_c);
	// logging(logfp, "%s] sizeof(atm_napas_trx_refno) -1: [%d", __func__, sizeof(atm_napas_trx_refno) -1);
	//logging(logfp, "%s] filler[60] : [%.*s", __func__, sizeof(atm_napas_trx_refno) -1, &MsgData.filler[60]);
	sprintf(atm_napas_trx_refno, "%.*s", sizeof(atm_napas_trx_refno) -1, &MsgData.filler[60]);
	sprintf(atm_otrnt_d, "%.*s", sizeof(atm_otrnt_d) -1, MsgData.atm_otrnt_d);
	memcpy(swc_svr_d, server_gb, sizeof(swc_svr_d) -1);

    memcpy(c_trdat, sdata, strlen(sdata) );
    rtrimString(c_trdat);

    LOGGER(LOG_DEBUG," TRX_BRNO : [%d",  trx_brno);
	LOGGER(LOG_DEBUG," ATM_TRX_TMN_NO : [%d",  atm_trx_tmn_no);
	LOGGER(LOG_DEBUG," ATM_TRX_TRACE_NO : [%d",  atm_trx_trace_no);
	LOGGER(LOG_DEBUG," GLB_ID : [%s",  glb_id);
	LOGGER(LOG_DEBUG," ATM_MSG_T_ID : [%s",  atm_msg_t_id);
	LOGGER(LOG_DEBUG," ATM_TRX_C : [%s",  atm_trx_c);
	LOGGER(LOG_DEBUG," PROC_NAME : [%s",  proc_name);
	LOGGER(LOG_DEBUG," ATM_PAN_CTT : [%s",  atm_pan_ctt);
	LOGGER(LOG_DEBUG," ATM_TRX_AMT : [%d",  atm_trx_amt);
	LOGGER(LOG_DEBUG," ATM_FORWD_DTTM : [%s",  atm_forwd_dttm);
	LOGGER(LOG_DEBUG," ATM_ACPN_ORG_RCGN_C : [%s",  atm_acpn_org_rcgn_c);
	LOGGER(LOG_DEBUG," TRX_CCY_C : [%s",  trx_ccy_c);
	LOGGER(LOG_DEBUG," ATM_NTW_MNG_INF_CTT : [%s",  atm_ntw_mng_inf_ctt);
	LOGGER(LOG_DEBUG," ATM_ORGTRX_DATA_CTT : [%s",  atm_orgtrx_data_ctt);
	LOGGER(LOG_DEBUG," ATM_WTHD_AC_RCGN_NO : [%s",  atm_wthd_ac_rcgn_no);
	LOGGER(LOG_DEBUG," ATM_RCPT_AC_RCGN_NO : [%s",  atm_rcpt_ac_rcgn_no);
	LOGGER(LOG_DEBUG," ATM_ACPN_MAN_RCGN_C : [%d",  atm_acpn_man_rcgn_c);
	LOGGER(LOG_DEBUG," STMT_AMT : [%d",  stmt_amt);
	LOGGER(LOG_DEBUG," CLAIM_AMT : [%d",  claim_amt);
	LOGGER(LOG_DEBUG," STMT_EXRT : [%d",  stmt_exrt);
	LOGGER(LOG_DEBUG," CLAIM_EXRT : [%d",  claim_exrt);
	LOGGER(LOG_DEBUG," STMT_CCY_C : [%s",  stmt_ccy_c);
	LOGGER(LOG_DEBUG," CLAIM_CCY_C : [%s",  claim_ccy_c);
	LOGGER(LOG_DEBUG," ATM_MDM_D : [%s",  atm_mdm_d);
	LOGGER(LOG_DEBUG," OTR_SRCH_REFNO : [%s",  otr_srch_refno);
	LOGGER(LOG_DEBUG," OTR_RESPOND_C : [%s",  otr_respond_c);
	LOGGER(LOG_DEBUG," ATM_DSPCH_ORG_RCGN_C : [%d",  atm_dspch_org_rcgn_c);
	LOGGER(LOG_DEBUG," ATM_NAPAS_TRX_REFNO : [%s",  atm_napas_trx_refno);
	LOGGER(LOG_DEBUG," ATM_OTRNT_D : [%s",  atm_otrnt_d);
	LOGGER(LOG_DEBUG," SWC_SVR_D : [%s",  swc_svr_d);
	LOGGER(LOG_DEBUG," NAPAS_MSG_DTL_CTT : [%s",  c_nap_data);
	LOGGER(LOG_DEBUG," ATM_MSG_DTL_CTT : [%s",  c_trdat);

    EXEC SQL
    	INSERT INTO DBOWN.GAT_SWSNAPRCV_LOG
		(
            SH_LCL_CORP_C
            , TRX_DT
            , ATM_LGGTM
            , NAPAS_PROC_ID
            , NORM_PROC_YN
            , ATM_TRX_TRACE_NO
            , GLB_ID
            , ATM_MSG_T_ID
            , ATM_TRX_C
            , PGM_NM_ID
            , TRX_TMNNO
            , ATM_PAN_CTT
            , ATM_TRX_AMT
            , ATM_FORWD_DTTM
            , ATM_ACPN_ORG_RCGN_C
            , TRX_CCY_C
            , ATM_NTW_MNG_INF_CTT
            , ATM_ORGTRX_DATA_CTT
            , ATM_WTHD_AC_RCGN_NO
            , ATM_RCPT_AC_RCGN_NO
            , ATM_ACPN_MAN_RCGN_C
            , STMT_AMT
            , CLAIM_AMT
            , STMT_EXRT
            , CLAIM_EXRT
            , STMT_CCY_C
            , CLAIM_CCY_C
            , ATM_MDM_D
            , OTR_SRCH_REFNO
            , OTR_RESPOND_C
            , ATM_DSPCH_ORG_RCGN_C
            , ATM_NAPAS_TRX_REFNO
            , ATM_OTRNT_D
            , TRX_RQST_TIME
            , TRX_RESPOND_TIME
            , BIZ_ERR_C
            , BIZ_ERR_C_CTT
            , NAPAS_MSG_DTL_CTT
            , ATM_MSG_DTL_CTT
            , INF_REGIS_DT
            , INF_REGIS_TIME
            , INF_REGIS_BUSS_DT
            , INF_REGIS_BNKERNO
            , INF_LCHG_DT
            , INF_LCHG_TIME
            , INF_LAST_CORC_BUSS_DT
            , INF_LCHG_MAN_BNKERNO
            , TRX_BRNO
            , SWC_SVR_D
        )
        VALUES
        (
            130
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , TO_CHAR(SYSDATE, 'YYMM') || LPAD(dbown.gat_swsn_rcv_seq_01.nextval,8,0)
            , :napas_proc_id
            , 0
            , :atm_trx_trace_no
            , :glb_id
            , :atm_msg_t_id
            , :atm_trx_c
            , :proc_name
            , :atm_trx_tmn_no
            , :atm_pan_ctt
            , :atm_trx_amt
            , :atm_forwd_dttm
            , :atm_acpn_org_rcgn_c
            , :trx_ccy_c
            , :atm_ntw_mng_inf_ctt
            , :atm_orgtrx_data_ctt
            , :atm_wthd_ac_rcgn_no
            , :atm_rcpt_ac_rcgn_no
            , :atm_acpn_man_rcgn_c
            , :stmt_amt
            , :claim_amt
            , :stmt_exrt
            , :claim_exrt
            , :stmt_ccy_c
            , :claim_ccy_c
            , :atm_mdm_d
            , :otr_srch_refno
            , :otr_respond_c
            , :atm_dspch_org_rcgn_c
            , :atm_napas_trx_refno
            , :atm_otrnt_d
            , TO_CHAR(SYSDATE, 'HH24MISS')
            , ''
            , ''
            , ''
            , :nap_data
            , :c_trdat
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , TO_CHAR(SYSDATE, 'HH24MISS')
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , ''
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , TO_CHAR(SYSDATE, 'HH24MISS')
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , ''
            , :trx_brno
            , :swc_svr_d
        )
    ;
    if (SQL_ERROR)
    {
		LOGGER(LOG_ERROR,"INSERT GAT_SWSNAPRCV_LOG ERROR [%d", SQLCODE);
        EXEC SQL ROLLBACK WORK;
        return ABNORMAL;
    }
    else
    {
		LOGGER(LOG_DEBUG,"INSERT GAT_SWSNAPRCV_LOG SUCCESS", "");
        EXEC SQL COMMIT WORK;
    }

    return NORMAL;
}


