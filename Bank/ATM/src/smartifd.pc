int alarm_handler()
{
	LOGGER(LOG_INFO,"called !!","");
	signal(SIGALRM, alarm_handler);
	return NORMAL;
}   


/*----------------------------------------------------------------------------*/     
/* FUNCTION : sendPOSMsgToNAPAS                                                     */
/* SUBJECT  : Send Data to NAPAS                                              */
/* RETURN   : SUCCESS: NORMAL                                                 */
/*----------------------------------------------------------------------------*/
int sendPOSMsgToNAPAS()
{    
    int   iret, tcpcnt;
    char  tmpcnt[10];
    char  s_tmpbuf[MAX_DPDATALEN+1];

	LOGGER(LOG_INFO,"..start.","");

	if ((iret = writeSocket(sockfd, SendBuffer, SendLength+4)) <= 0)
	{
		LOGGER(LOG_ERROR,"writeSocket(). [%d",errno);
		return ABNORMAL;
	}

    if (SendLength+4 != iret)
    {
		LOGGER(LOG_ERROR,"LENGTH of SENT DATA to NAPAS [send=%d sent=%d",SendLength+4,iret);
        return ABNORMAL;
    }

	LOGGER(LOG_INFO,"SEND][DPIF -> DP    ][%s",SendBuffer);
	LOGGER(LOG_INFO,"....end.","");

    return NORMAL;
}
  
/*----------------------------------------------------------------------------*/
/* Function Name : Get POS Acquiring Message                                  */
/* Description   : Get Received POS message from GAT_SWSACQRCV_LOG            */
/*----------------------------------------------------------------------------*/
int getMsgFromPOS()
{
	int     ilen, ix;
    int     sendlen = 0;
    int     recvlen = 0;
    char    trdat [MAX_DPDATALEN+1];
    char    isodat[MAX_DPDATALEN+1];
    char    s_tmpbuf[MAX_DPDATALEN+1];
    char    tmpcnt[10];
    char    trlen[10]= {0x00, };
    char    msgtype[5] = {0x00, };
    char    pcode  [7] = {0x00, };
    char    hlength[5];

    memset(trdat  , 0x00, sizeof(trdat  ));
    memset(&ChnlHead, 0x00, sizeof(ChnlHead));  
    memset(&MsgHead , 0x00, sizeof(MsgHead ));  
    memset(&MsgFix  , 0x00, sizeof(MsgFix  ));  
    memset(&MsgCom  , 0x00, sizeof(MsgCom  ));  
    memset(&MsgData , 0x00, sizeof(MsgData )); 

	EXEC SQL BEGIN DECLARE SECTION;
		char sel_date   [ 8 + 1] = {0x00, };
		char sel_glbId  [32 + 1] = {0x00, };
		char sel_pname  [20 + 1] = {0x00, };
		char sel_data   [4000 + 1] = {0x00, };
		char c_tmp      [ 3 + 1] = {0x00, };
		char ibt_msg_t  [4  + 1] = {0x00, };
	EXEC SQL END DECLARE SECTION;

    EXEC SQL DECLARE c_acqRcvInfo CURSOR FOR
    SELECT /*+ INDEX_SS(GAT_SWSACQRCV_LOG GAT_SWSACQRCV_LOG_IX_04) */ 
		TRX_DT, GLB_ID
    // FROM DBOWN.GAT_SWSACQRCV_LOG
	FROM DBOWN.GAT_SWSACQRCV_LOG
    WHERE SH_LCL_CORP_C = 130
		AND TRX_DT >= TO_CHAR(SYSDATE -1, 'YYYYMMDD')
       	AND NAPAS_PROC_ID = 'ETC'
       	AND NORM_PROC_YN = 0
    ORDER BY TRX_DT, ATM_LGGTM ASC
    ;

    EXEC SQL OPEN c_acqRcvInfo;
	while(1)
    {
    	memset(sel_date, 0x00, sizeof(sel_date) -1 );
        memset(sel_glbId, 0x00, sizeof(sel_glbId) -1 );
        memset(sel_pname, 0x00, sizeof(sel_pname) -1 );
        memset(sel_data, 0x00, sizeof(sel_data) -1 );

        EXEC SQL FETCH c_acqRcvInfo INTO :sel_date, :sel_glbId;
		rtrimString(sel_glbId);
        if (sel_date[0] == 0x00 || sel_date[0] == 0x20)
            break;

		LOGGER(LOG_DEBUG,"sel_date : sel_time [%s : %s", sel_date, sel_glbId);

        EXEC SQL
        SELECT PGM_NM_ID, ATM_MSG_DTL_CTT
          	INTO :sel_pname, :sel_data
        FROM DBOWN.GAT_SWSACQRCV_LOG  
        WHERE SH_LCL_CORP_C = 130
           	AND TRX_DT = :sel_date
           	AND TRIM(GLB_ID) = :sel_glbId
           	AND NAPAS_PROC_ID = 'ETC'
           	AND NORM_PROC_YN = 0
        ORDER BY TRX_DT, ATM_LGGTM ASC
        ;
        if (SQL_ERROR)
        {
            if (SQL_NOTFOUND)
            {
				LOGGER(LOG_ERROR,"SELECT DATA FOT FOUND","");
				EXEC SQL CLOSE c_acqRcvInfo;
                return NODATA;
            }
			LOGGER(LOG_ERROR,"SELECT ERROR : [%d",SQLCODE);			
			EXEC SQL CLOSE c_acqRcvInfo;
            return ABNORMAL;
        }
        else
        {
            EXEC SQL
            UPDATE DBOWN.GAT_SWSACQRCV_LOG
            	SET NORM_PROC_YN = 1
            WHERE SH_LCL_CORP_C = 130
            	AND TRX_DT = :sel_date
           		AND TRIM(GLB_ID) = :sel_glbId
           		AND NAPAS_PROC_ID = 'ETC'
           		AND NORM_PROC_YN = 0
            ;

            if (SQL_ERROR)
            {
				LOGGER(LOG_ERROR,"UPDATE SELECT ERROR : [%d",SQLCODE);
                EXEC SQL ROLLBACK WORK;
				EXEC SQL CLOSE c_acqRcvInfo;
                return ABNORMAL;
            }
            else
            {
				LOGGER(LOG_DEBUG,"UPDATE SUCCESS : [%s:%s",sel_date, sel_glbId);
                EXEC SQL COMMIT WORK;
            }

        }
        rtrimString(sel_data);

		ix = 0;
		memcpy(&ChnlHead , &sel_data[ix] , sizeof(ChnlHead));
		/*---------------------------------------------------------------*/
		/* POS-RECEIVE DATA COMMON VARIABLE SET                          */
		/*---------------------------------------------------------------*/
		ix += sizeof(ChnlHead);
		memcpy(&MsgCom  , &sel_data[ix] , sizeof(MsgCom));
		
		ix += sizeof(MsgCom);
		memcpy(&MsgData , &sel_data[ix] , sizeof(MsgData));
		
		LOGGER(LOG_INFO, "RECV][POS -> ATMIF][msgtype=%.*s pcode=%.*s][recv_svc_c=%.*s][glob_id=%.*s][traceNo=%.*s"
			, sizeof(MsgData.msgtype), MsgData.msgtype
			, sizeof(MsgData.bit_3), MsgData.bit_3
			, sizeof(ChnlHead.recv_svc_c), ChnlHead.recv_svc_c
			, 30, ChnlHead.chl_filler  
			, sizeof(MsgData.bit_11), MsgData.bit_11);


		memset(&MsgHead.trm_set_brno  , 0x00 , sizeof(MsgHead.trm_set_brno));
		memset(&MsgHead.trm_set_trmno , 0x00 , sizeof(MsgHead.trm_set_trmno));
		memcpy(MsgHead.trm_set_brno  , ChnlHead.trxbrno   , sizeof(MsgHead.trm_set_brno));
		memcpy(MsgHead.trm_set_trmno , ChnlHead.trx_trmno , sizeof(MsgHead.trm_set_trmno));

		char msgtype[4+1] = {0x00,};
		char pcode[6+1] = {0x00,};
		memcpy(msgtype, MsgData.msgtype, sizeof(MsgData.msgtype));
		memcpy(pcode  , MsgData.bit_3  , sizeof(MsgData.bit_3));
		if ( OasistoIso8583(1, msgtype, pcode, g_log_lvl) == ABNORMAL )
		{
			LOGGER(LOG_ERROR,"OasistoIso8583() msgtype[%s]pcode[%s", msgtype, pcode);
			return ABNORMAL;
		}
		  
		char logpath[100] = {0x00, };
		char headBuff[MAX_FIFO_SIZE+1] = {0x00, };
		memcpy(headBuff, &ChnlHead, sizeof(ChnlHead));
		sprintf(logpath, "BCVN%.10s%.8s%.4s", MsgData.bit_7, MsgData.bit_41, &MsgData.bit_11[2]);
		fWrite(logpath, headBuff, MAX_FIFO_SIZE);
		
    	/*---------------------------------------------------------------*/
    	/* DP I/F -> DP send DATA                                        */
    	/*---------------------------------------------------------------*/
    	if (sendPOSMsgToNAPAS() == ABNORMAL) 
		{
			EXEC SQL CLOSE c_acqRcvInfo;
			return ABNORMAL;
		}
	}
	EXEC SQL CLOSE c_acqRcvInfo;
    return NORMAL;
}


int pushMsgToPOS(char * sdata){
    memset(&ChnlHead, 0x00, sizeof(ChnlHead));     
	char buffer[MAX_FIFO_SIZE+1] = {0x00, };
	char lenbuff[20] = {0x00};
    char fname[500] = {0x00, };
    int ix;   
	int ilen = 0;  
    int i;   
    
    sprintf(fname, "BCVN%.10s%.8s%.4s", MsgData.bit_7, MsgData.bit_41, &MsgData.bit_11[2]);
    
   	if(read_fifo(fname, buffer, MAX_FIFO_SIZE) != NORMAL ){
		LOGGER(LOG_ERROR,"Extracting Channel Header Fail ","");
		return ABNORMAL;
	}        

    memcpy(&ChnlHead, buffer, sizeof(ChnlHead));  
   
	ilen = sizeof(ChnlHead)-sizeof(ChnlHead.chl_len) +sizeof(MsgData);
    sprintf(lenbuff, "%08d", ilen);
	memcpy(ChnlHead.chl_len, lenbuff, strlen(lenbuff));
	
	char c_trx_brno             [ 4 + 1] = {0x00, };
	char c_atm_trx_tmn_no       [ 4 + 1] = {0x00, };
	char c_atm_trx_trace_no     [ 6 + 1] = {0x00, };   
	char c_atm_trx_amt          [12 + 1] = {0x00, };
	char c_atm_acpn_man_rcgn_c  [11 + 1] = {0x00, };
	char c_atm_dspch_org_rcgn_c [11 + 1] = {0x00, };

	EXEC SQL BEGIN DECLARE SECTION;
		int  trx_brno               = 0;
		int  atm_trx_tmn_no         = 0;
		int  atm_trx_trace_no       = 0;
		// char glb_id                 [30 + 1] = {0x00, };
		char glb_id                 [32 + 1] = {0x00, };
		char atm_msg_t_id           [ 4 + 1] = {0x00, };
		char atm_trx_c              [ 6 + 1] = {0x00, };
		char proc_name              [ 8 + 1] = {0x00, };
		char atm_pan_ctt            [19 + 1] = {0x00, };
		int  atm_trx_amt            = 0;
		char atm_forwd_dttm         [14 + 1] = {0x00, };
		char atm_acpn_org_rcgn_c    [11 + 1] = {0x00, };
		char trx_ccy_c              [ 3 + 1] = {0x00, };   
		char atm_ntw_mng_inf_ctt    [ 3 + 1] = {0x00, };
		char atm_orgtrx_data_ctt    [42 + 1] = {0x00, };
		char atm_wthd_ac_rcgn_no    [28 + 1] = {0x00, };
		char atm_rcpt_ac_rcgn_no    [28 + 1] = {0x00, };
		int  atm_acpn_man_rcgn_c    = 0;
		char atm_mdm_d              [ 2 + 1] = {0x00, };
		char otr_srch_refno         [12 + 1] = {0x00, };
		char otr_respond_c          [ 2 + 1] = {0x00, };
		int  atm_dspch_org_rcgn_c   = 0;
		char atm_napas_trx_refno    [16 + 1] = {0x00, };
		char atm_otrnt_d            [ 2 + 1] = {0x00, };
		char swc_svr_d              [ 1 + 1] = {0x00, };  
		char c_trdat                [4000+1] = {0x00, };
		char iso_trdat               [500+1] = {0x00, };
	EXEC SQL END DECLARE SECTION;

	memcpy(c_trx_brno, ChnlHead.trxbrno, sizeof(c_trx_brno) -1);
	trx_brno = atoi(c_trx_brno);
	memcpy(c_atm_trx_tmn_no, ChnlHead.trx_trmno, sizeof(c_atm_trx_tmn_no) -1);
	atm_trx_tmn_no = atoi(c_atm_trx_tmn_no);
	memcpy(c_atm_trx_trace_no, MsgData.bit_11, sizeof(c_atm_trx_trace_no) -1);  
	atm_trx_trace_no = atoi(c_atm_trx_trace_no);
	// memcpy(glb_id, MsgHead.glob_id, sizeof(glb_id) -1);

	sprintf(glb_id, "%.30s", ChnlHead.chl_filler);
	memcpy(atm_msg_t_id, MsgData.msgtype, sizeof(atm_msg_t_id) -1);
	memcpy(atm_trx_c, MsgData.bit_3, sizeof(atm_trx_c) -1);
	memcpy(proc_name, ChnlHead.buf_address, sizeof(proc_name) -1);  
	memcpy(atm_pan_ctt, MsgData.bit_2, sizeof(atm_pan_ctt) -1);
	memcpy(c_atm_trx_amt, MsgData.bit_4, sizeof(c_atm_trx_amt) -1);
	atm_trx_amt = atoi(c_atm_trx_amt);
	memcpy(atm_forwd_dttm, MsgData.bit_7, sizeof(atm_forwd_dttm) -1);
	memcpy(atm_acpn_org_rcgn_c, MsgData.bit_32, sizeof(atm_acpn_org_rcgn_c) -1);
	memcpy(trx_ccy_c, MsgData.bit_49, sizeof(trx_ccy_c) -1);
	memcpy(atm_ntw_mng_inf_ctt, MsgData.bit_70, sizeof(atm_ntw_mng_inf_ctt) -1);
	memcpy(atm_orgtrx_data_ctt, MsgData.bit_90, sizeof(atm_orgtrx_data_ctt) -1);
	memcpy(atm_wthd_ac_rcgn_no, MsgData.bit_102, sizeof(atm_wthd_ac_rcgn_no) -1);
	memcpy(atm_rcpt_ac_rcgn_no, MsgData.bit_103, sizeof(atm_rcpt_ac_rcgn_no) -1);
	memcpy(c_atm_acpn_man_rcgn_c, MsgData.bit_100, sizeof(c_atm_acpn_man_rcgn_c) -1);
	atm_acpn_man_rcgn_c = atoi(c_atm_acpn_man_rcgn_c);
	memcpy(atm_mdm_d, MsgData.atm_mdm_d, sizeof(atm_mdm_d) -1);
	memcpy(otr_srch_refno, MsgData.bit_37, sizeof(otr_srch_refno) -1);
	memcpy(otr_respond_c, MsgData.bit_39, sizeof(otr_respond_c) -1);
	memcpy(c_atm_dspch_org_rcgn_c, MsgData.bit_33, sizeof(c_atm_dspch_org_rcgn_c) -1);
	atm_dspch_org_rcgn_c = atoi(c_atm_dspch_org_rcgn_c);
	memcpy(atm_napas_trx_refno, &MsgData.filler[60], sizeof(atm_napas_trx_refno) -1);
	memcpy(atm_otrnt_d, MsgData.atm_otrnt_d, sizeof(atm_otrnt_d) -1);
	memcpy(swc_svr_d, server_gb, sizeof(swc_svr_d) -1);
    
	memcpy(MsgData.etx, "ZZ", sizeof(MsgData.etx) );   
	memcpy(iso_trdat, sdata, sizeof(iso_trdat) - 1 );
	rtrimString(iso_trdat);
	int indx = 0;
    memcpy(&c_trdat[indx] , &ChnlHead, sizeof(ChnlHead ));   
    indx += sizeof(ChnlHead);
    memcpy(&c_trdat[indx] , &MsgData, sizeof(MsgData )); 
	rtrimString(c_trdat);
    
    EXEC SQL
	INSERT INTO DBOWN.GAT_SWSACQSND_LOG
	(
		SH_LCL_CORP_C
		,TRX_DT
		,ATM_LGGTM
		,NAPAS_PROC_ID
		,NORM_PROC_YN
		,ATM_TRX_TRACE_NO
		,GLB_ID
		,ATM_MSG_T_ID
		,ATM_TRX_C
		,PGM_NM_ID
		,TRX_TMNNO
		,ATM_PAN_CTT
		,ATM_TRX_AMT
		,ATM_FORWD_DTTM
		,ATM_ACPN_ORG_RCGN_C
		,TRX_CCY_C
		,ATM_NTW_MNG_INF_CTT
		,ATM_ORGTRX_DATA_CTT
		,ATM_WTHD_AC_RCGN_NO
		,ATM_RCPT_AC_RCGN_NO
		,ATM_ACPN_MAN_RCGN_C
		,ATM_MDM_D
		,OTR_SRCH_REFNO
		,OTR_RESPOND_C
		,ATM_DSPCH_ORG_RCGN_C
		,ATM_NAPAS_TRX_REFNO
		,ATM_OTRNT_D
		,TRX_RQST_TIME
		,TRX_RESPOND_TIME
		,BIZ_ERR_C
		,BIZ_ERR_C_CTT
		,NAPAS_MSG_DTL_CTT
		,ATM_MSG_DTL_CTT
		,INF_REGIS_DT
		,INF_REGIS_TIME
		,INF_REGIS_BUSS_DT
		,INF_REGIS_BNKERNO
		,INF_LCHG_DT
		,INF_LCHG_TIME
		,INF_LAST_CORC_BUSS_DT
		,INF_LCHG_MAN_BNKERNO
		,TRX_BRNO
		,SWC_SVR_D
	)
	VALUES
	(
		130
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, TO_CHAR(SYSDATE, 'YYMMddhh24miss')
		, 'ETC'
		, 0
		, :atm_trx_trace_no
		, :glb_id
		, :atm_msg_t_id
		, :atm_trx_c
		, :proc_name
		, :atm_trx_tmn_no
		, :atm_pan_ctt
		, :atm_trx_amt
		, :atm_forwd_dttm
		, :atm_acpn_org_rcgn_c
		, :trx_ccy_c
		, :atm_ntw_mng_inf_ctt
		, :atm_orgtrx_data_ctt
		, :atm_wthd_ac_rcgn_no
		, :atm_rcpt_ac_rcgn_no
		, :atm_acpn_man_rcgn_c
		, :atm_mdm_d
		, :otr_srch_refno
		, :otr_respond_c
		, :atm_dspch_org_rcgn_c
		, :atm_napas_trx_refno
		, :atm_otrnt_d
		, TO_CHAR(SYSDATE, 'HH24MISS')
		, TO_CHAR(SYSDATE, 'HH24MISS')
		, ''
		, ''
		, :iso_trdat
		, :c_trdat
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, TO_CHAR(SYSDATE, 'HH24MISS')
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, ''
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, TO_CHAR(SYSDATE, 'HH24MISS')
		,  TO_CHAR(SYSDATE, 'YYYYMMDD')
		, ''
		, :trx_brno
		, :swc_svr_d
	)
	;

	if (SQL_ERROR)
	{
		LOGGER(LOG_ERROR,"INSERT GAT_SWSACQSND_LOG ERROR [%d", SQLCODE);
		EXEC SQL ROLLBACK WORK;
		return ABNORMAL;
	}
	else
	{
		LOGGER(LOG_DEBUG,"INSERT GAT_SWSACQSND_LOG SUCCESS","");
		EXEC SQL COMMIT WORK;
	}
	return NORMAL;  
}

int keyStore(char *keyType, char *keyVal, char *kcv){

	EXEC SQL BEGIN DECLARE SECTION;
		char atm_estbls_trx_c   [ 20 + 1] = {0x00, };
		char atm_estbls_id   [20 + 1] = {0x00, };
		char atm_estbls_nm  [40 + 1] = {0x00, };
		char atm_estbls_ctt   [200 + 1] = {0x00, };
	EXEC SQL END DECLARE SECTION;
	memcpy(atm_estbls_id, keyType, sizeof(atm_estbls_id) - 1);

    char  tmp[200];
    memset(tmp, 0x00, sizeof(tmp));

    memcpy(tmp, keyVal, strlen(keyVal));

	LOGGER(LOG_INFO,"Dynamic key : [%s",tmp);
	
	memcpy(atm_estbls_ctt, keyVal, strlen(keyVal));
	rtrimString(atm_estbls_ctt);
	memcpy(atm_estbls_nm, kcv, strlen(kcv));
	rtrimString(atm_estbls_nm);
	EXEC SQL  
	UPDATE DBOWN.GAT_SWSCONF_INF  
		SET ATM_ESTBLS_NM = :atm_estbls_nm,
			ATM_ESTBLS_CTT =:atm_estbls_ctt   
		WHERE SH_LCL_CORP_C = 130
		AND ATM_ESTBLS_TRX_C = 'CONF'
		AND ATM_ESTBLS_ID = :atm_estbls_id
	;

	if (SQL_ERROR)
	{
		LOGGER(LOG_ERROR,"UPDATE SELECT ERROR : [%d", SQLCODE);
		EXEC SQL ROLLBACK WORK;
		return ABNORMAL;
	}

	LOGGER(LOG_INFO,"UPDATE SUCCESS : [%s - %s",atm_estbls_id,atm_estbls_nm);
	EXEC SQL COMMIT WORK;
	return NORMAL;

}

int keyExchHandler(char * msgType){
	char curDate[8 + 1] = {0x00,};
	char tmp[21 + 1] = {0x00,};
    hsmManagement_in temporaryInput;   
	hsmManagement_out temporaryOutput;
	INIT_hsmManagement_out(temporaryOutput);    
	INIT_hsmManagement_in(temporaryInput);
	getDate(tmp);
	memcpy(curDate,tmp, sizeof(curDate) -1);  
	char bit_48_len[3 + 1] = {0x00,};
	int  key_len[3 + 1] = {0x00,};
	char key_type[3 + 1] = {0x00,};   
	char ZMKey[200] = {0x00,};
	char encKey[200] = {0x00,};  
	char formKey[200] = {0x00,};  
	memcpy(bit_48_len, HMERecv.Data[48], 3);
	LOGGER(LOG_INFO,"Start Exchange Key bit_48_len[%s]",bit_48_len);

	int len = 0;
	if( ( len = atoi(bit_48_len) ) < 38 )
	{
		LOGGER(LOG_ERROR,"BIT_48 Invalid len[%ld]", len);
		goto SEND_EXCH_FAIL_TO_NAP; 
	}

	memset(ZMKey, 0x00, sizeof(ZMKey));
	if (getNewConfigData("ZMASTKEY_AES", ZMKey) == ABNORMAL)
	{
		LOGGER(LOG_ERROR,"Load ZMK Fail", "");
		goto SEND_EXCH_FAIL_TO_NAP; 
	}   

	memcpy(key_type, HMERecv.Data[48] + 3 , 3);
	memcpy(key_len, HMERecv.Data[48] + 6, 3);
	logging(logfp, "%s] Dynamic Key Type[%s]len[%s]", __func__, key_type, key_len);
	memcpy(encKey, HMERecv.Data[48] + 10, atoi(key_len));

	if(memcmp(&key_type, "ZPK", 3) == 0 || memcmp(&key_type, "MAK", 3) == 0){

		char kcv[6 + 1] = {0x00,};

		temporaryInput.trx_func_d = 			TRX_D_IMPORT_ZPKKEY;
		temporaryInput.brd_connt_port_no = 		atoi(hsm_newPort);
		memcpy(temporaryInput.zmk_ctt, 			ZMKey, 				sizeof(temporaryInput.zmk_ctt) -1);
		memcpy(temporaryInput.lmk_id, 			"01", 				sizeof(temporaryInput.lmk_id) -1);  // LMK Identifier for AES
		memcpy(temporaryInput.src_zpk_ctt, 	    encKey, 			sizeof(temporaryInput.src_zpk_ctt) -1);
		memcpy(temporaryInput.tmn_ip, 			hsm_newIp, 			sizeof(temporaryInput.tmn_ip) - 1);
		memcpy(temporaryInput.rqst_svc_c, 		HSM_SND_ID_SMTIFD,	sizeof(temporaryInput.rqst_svc_c));


		if( hsmManagement(&temporaryInput, &temporaryOutput) != NORMAL ){
			LOGGER(LOG_ERROR, "AES Zpk Import Fail : [%s-%s]", encKey ,temporaryOutput.atm_respond_c );
			goto SEND_EXCH_FAIL_TO_NAP; 
		}
	
		if(memcmp(temporaryOutput.atm_respond_c, "00", 2 ) != 0){
			LOGGER(LOG_ERROR, "hsmManagement Respond Error [%s]", temporaryOutput.atm_respond_c);
			goto SEND_EXCH_FAIL_TO_NAP; 
		}   
		
		LOGGER(LOG_INFO,"hsmManagement_out key[%.*s] KCV[%.*s", 
						sizeof(temporaryOutput.dest_zpk_ctt),temporaryOutput.dest_zpk_ctt,
						sizeof(temporaryOutput.mac_ctt),temporaryOutput.mac_ctt);
  
		memcpy(formKey, temporaryOutput.dest_zpk_ctt, 	sizeof(formKey) -1 ); 
		memcpy(kcv, 	temporaryOutput.mac_ctt, 		sizeof(kcv) -1 ); 
		rtrimString(formKey);


		if(memcmp(&key_type, "ZPK", 3) == 0){
			if(keyStore("DP_CLEAR_AESKEY", formKey, kcv) != NORMAL){
				goto SEND_EXCH_FAIL_TO_NAP; 
			}
			// if(keyStore("DP_CLEAR_AESKEY2", encKey, ZMKey) != NORMAL){
			// 	goto SEND_EXCH_FAIL_TO_NAP; 
			// }
		}else{
			// if(keyStore("DP_ZAKKEY", encKey, ZMKey) != NORMAL){
				goto SEND_EXCH_FAIL_TO_NAP; 
			// }
		}
		
		newkeyLoadInval = 100*60;
		memcpy(&SendBuffer[4], "0810", 4);   

		char fname[50] = {0x00, };
		sprintf(fname, "%.10s_key_exchg.dat","smartifi");
		fWrite(fname, curDate, sizeof(curDate));      
		memset(fname, 0x00, sizeof(fname));
		sprintf(fname, "%.10s_key_exchg.dat","smartifo");
		fWrite(fname, curDate, sizeof(curDate));
		memset(fname, 0x00, sizeof(fname));           
		sprintf(fname, "%.10s_key_exchg.dat","smartifd");   
		fWrite(fname, curDate, sizeof(curDate));
		memset(fname, 0x00, sizeof(fname));
		sprintf(fname, "%.10s_key_exchg.dat","smartifn");
		fWrite(fname, curDate, sizeof(curDate));
   
		sendNetworkRspNAPAS();

		LOGGER(LOG_INFO,"WRIT][DPIF -> HOSTIF] SendBuffer[%.*s",SendLength + 4, SendBuffer);

	}else{
		LOGGER(LOG_INFO,"BIT_48 Key Type not support [%s", key_type);
		goto SEND_EXCH_FAIL_TO_NAP; 
	}

	return NORMAL;

SEND_EXCH_FAIL_TO_NAP : 

	if (memcmp(&SendBuffer[4], "0800", 4) == 0)
	{   
		HMESend.DataLength[1] = 0;   
		memcpy(HMESend.Data[39], "01", 2);  
		memset(HMESend.Data[1], 0, sizeof(HMESend.Data[1]));
		makeBitmap2();
		memcpy(&SendBuffer[4], "0810", 4);  
     
		sendNetworkRspNAPAS();  

		LOGGER(LOG_INFO,"WRIT][DPIF -> HOSTIF] SendBuffer[%.*s",SendLength + 4, SendBuffer);
	}
	return ABNORMAL;

}
  
int keyReload(char *exeName){
	char curDate[8 + 1] = {0x00,};
	char tmp[21 + 1] = {0x00,};
	char buffer[8+1] = {0x00,};  
    char fname[500] = {0x00,};     
      
	getDate(tmp);     
	memcpy(curDate,tmp, sizeof(curDate) -1);        
    sprintf(fname, "%.10s_key_exchg.dat",exeName);     
    
   	if(read_fifo(fname, buffer, sizeof(buffer)) != NORMAL ){  
		
		memcpy(buffer,"99991231", sizeof(buffer));    
		fWrite(fname, buffer, sizeof(buffer));       
		newkeyLoadInval = 0;  
		return NORMAL;     
	}           

	if( memcmp(curDate,buffer, 8) >= 0 ){
		if(loadDesKey() == NORMAL){
			fWrite(fname, "99991231", sizeof(buffer));
			
		}else{
			LOGGER(LOG_ERROR,"Reload Key Fail !!!","");
		}
	}
	newkeyLoadInval = 0;
}

int signTrxHandler(char * msgType){

	char c_trx_brno             [ 4 + 1] = {0x00, };
    char c_atm_trx_tmn_no       [ 4 + 1] = {0x00, };
    char c_atm_trx_trace_no     [ 6 + 1] = {0x00, };
    char c_atm_trx_amt          [12 + 1] = {0x00, };
    char c_atm_acpn_man_rcgn_c  [11 + 1] = {0x00, };
    char c_stmt_amt             [12 + 1] = {0x00, };
    char c_claim_amt            [12 + 1] = {0x00, };
    char c_stmt_exrt            [ 8 + 1] = {0x00, };    
    char c_claim_exrt           [ 8 + 1] = {0x00, };
    char c_atm_dspch_org_rcgn_c [11 + 1] = {0x00, };
    char c_nap_data             [500+ 1] = {0x00, };

EXEC SQL BEGIN DECLARE SECTION;
    int  trx_brno               = 0;
    int  atm_trx_trace_no       = 0;
    int  atm_trx_tmn_no         = 0;
    char napas_proc_id          [ 3 + 1] = {0x00, };
    // char glb_id                 [30 + 1] = {0x00, };
    char glb_id                 [32 + 1] = {0x00, };
    char atm_msg_t_id           [ 4 + 1] = {0x00, };
    char atm_trx_c              [ 6 + 1] = {0x00, };
    char proc_name              [ 8 + 1] = {0x00, };
    char atm_pan_ctt            [19 + 1] = {0x00, };
    int  atm_trx_amt            = 0;
    char atm_forwd_dttm         [14 + 1] = {0x00, };
    char atm_acpn_org_rcgn_c    [11 + 1] = {0x00, };
    char trx_ccy_c              [ 3 + 1] = {0x00, };
    char atm_ntw_mng_inf_ctt    [ 3 + 1] = {0x00, };
    char atm_orgtrx_data_ctt    [42 + 1] = {0x00, };
    char atm_wthd_ac_rcgn_no    [28 + 1] = {0x00, };
    char atm_rcpt_ac_rcgn_no    [28 + 1] = {0x00, };
    int  atm_acpn_man_rcgn_c    = 0;
    int  stmt_amt               = 0;
    int  claim_amt              = 0;
    int  stmt_exrt              = 0;
    int  claim_exrt             = 0;
    char stmt_ccy_c             [ 3 + 1] = {0x00, };
    char claim_ccy_c            [ 3 + 1] = {0x00, };
    char atm_mdm_d              [ 2 + 1] = {0x00, };
    char otr_srch_refno         [12 + 1] = {0x00, };
    char otr_respond_c          [ 2 + 1] = {0x00, };
    int  atm_dspch_org_rcgn_c   = 0;
    char atm_napas_trx_refno    [16 + 1] = {0x00, };
    char atm_otrnt_d            [ 2 + 1] = {0x00, };
    char swc_svr_d              [ 1 + 1] = {0x00, };
    char nap_data               [ 500+1] = {0x00, };
    char c_trdat                [4000+1] = {0x00, };
EXEC SQL END DECLARE SECTION;


    sprintf(c_nap_data, "%.*s", sizeof(c_nap_data), RecvBuffer);
    rtrimString(c_nap_data);
    memcpy(nap_data, c_nap_data, sizeof(nap_data) -1 );

    memcpy(c_atm_trx_trace_no, HMERecv.Data[11], sizeof(c_atm_trx_trace_no) -1);
    atm_trx_trace_no = atoi(c_atm_trx_trace_no);
    memcpy(atm_msg_t_id,HMERecv.Data[0], sizeof(atm_msg_t_id) -1);
    memcpy(atm_forwd_dttm, HMERecv.Data[7], sizeof(atm_forwd_dttm) -1);
    memcpy(atm_ntw_mng_inf_ctt, HMERecv.Data[70], sizeof(atm_ntw_mng_inf_ctt) -1);
    memcpy(otr_respond_c, HMERecv.Data[39], sizeof(otr_respond_c) -1);


    EXEC SQL
    	INSERT INTO DBOWN.GAT_SWSNAPRCV_LOG
		(
            SH_LCL_CORP_C
            , TRX_DT  
            , ATM_LGGTM
            , NAPAS_PROC_ID
            , NORM_PROC_YN
            , ATM_TRX_TRACE_NO
            , GLB_ID
            , ATM_MSG_T_ID
            , ATM_TRX_C
            , PGM_NM_ID
            , TRX_TMNNO
            , ATM_PAN_CTT
            , ATM_TRX_AMT
            , ATM_FORWD_DTTM
            , ATM_ACPN_ORG_RCGN_C
            , TRX_CCY_C
            , ATM_NTW_MNG_INF_CTT
            , ATM_ORGTRX_DATA_CTT
            , ATM_WTHD_AC_RCGN_NO
            , ATM_RCPT_AC_RCGN_NO
            , ATM_ACPN_MAN_RCGN_C
            , STMT_AMT
            , CLAIM_AMT
            , STMT_EXRT
            , CLAIM_EXRT
            , STMT_CCY_C
            , CLAIM_CCY_C
            , ATM_MDM_D
            , OTR_SRCH_REFNO
            , OTR_RESPOND_C
            , ATM_DSPCH_ORG_RCGN_C
            , ATM_NAPAS_TRX_REFNO
            , ATM_OTRNT_D
            , TRX_RQST_TIME
            , TRX_RESPOND_TIME
            , BIZ_ERR_C
            , BIZ_ERR_C_CTT
            , NAPAS_MSG_DTL_CTT
            , ATM_MSG_DTL_CTT
            , INF_REGIS_DT
            , INF_REGIS_TIME
            , INF_REGIS_BUSS_DT
            , INF_REGIS_BNKERNO
            , INF_LCHG_DT
            , INF_LCHG_TIME
            , INF_LAST_CORC_BUSS_DT
            , INF_LCHG_MAN_BNKERNO
            , TRX_BRNO
            , SWC_SVR_D
        )
        VALUES
        (
            130
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , TO_CHAR(SYSDATE, 'YYMM') || LPAD(dbown.gat_swsn_rcv_seq_01.nextval,8,0)
            , 'ETC'
            , 1
            , :atm_trx_trace_no
            , ''
            , :atm_msg_t_id
            , 'EXCKEY'
            , 'SGAT9468A001'
            , ''
            , '000000000000'
            , 0
            , :atm_forwd_dttm
            , '970424'
            , '704'
            , :atm_ntw_mng_inf_ctt
            , :atm_orgtrx_data_ctt  
            , :atm_wthd_ac_rcgn_no
            , :atm_rcpt_ac_rcgn_no
            , :atm_acpn_man_rcgn_c
            , :stmt_amt
            , :claim_amt
            , :stmt_exrt
            , :claim_exrt
            , :stmt_ccy_c
            , :claim_ccy_c
            , :atm_mdm_d
            , :otr_srch_refno
            , :otr_respond_c
            , :atm_dspch_org_rcgn_c
            , :atm_napas_trx_refno
            , :atm_otrnt_d
            , TO_CHAR(SYSDATE, 'HH24MISS')
            , ''
            , ''
            , ''
            , :nap_data
            , :c_trdat
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , TO_CHAR(SYSDATE, 'HH24MISS')
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , ''
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , TO_CHAR(SYSDATE, 'HH24MISS')
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , ''
            , 8061
            , :swc_svr_d
        )
    ;
    if (SQL_ERROR)
    {
		LOGGER(LOG_ERROR,"INSERT GAT_SWSNAPRCV_LOG ERROR [%d",SQLCODE);
        EXEC SQL ROLLBACK WORK;
        return ABNORMAL;
    }

	LOGGER(LOG_DEBUG,"INSERT GAT_SWSNAPRCV_LOG SUCCESS","");
    EXEC SQL COMMIT WORK;
    return NORMAL;

}

int fWrite(fname, buffer, size)
char *fname;
char *buffer;
int size;
{   
	char newfname[100] = {0x00, };  
	FILE *fifowrite;
	sprintf(newfname, "%s%s%s"
		, HOMEPATH, FILEPATH, fname);
	if((fifowrite = fopen(newfname, "w")) == (FILE *)NULL)
    {
		LOGGER(LOG_ERROR,"can't open write fifo: [%s] errno(%d)[%s",newfname, errno, UNIX_ERRMSG);
        return ABNORMAL;
    }

	chmod(newfname, 0666);
	if (fprintf(fifowrite, "%.*s", size, buffer) < 0)
    {
		LOGGER(LOG_ERROR,"fifo write failed [%s",newfname);
        fclose(fifowrite);
        return ABNORMAL;
    }

    fclose(fifowrite);
	return NORMAL;
}   
