		, :atm_rcpt_ac_rcgn_no
		, :atm_acpn_man_rcgn_c
		, :stmt_amt
		, :claim_amt
		, :stmt_exrt
		, :claim_exrt
		, :stmt_ccy_c
		, :claim_ccy_c
		, :atm_mdm_d
		, :otr_srch_refno
		, :otr_respond_c
		, :atm_dspch_org_rcgn_c
		, :atm_napas_trx_refno
		, :atm_otrnt_d
		, TO_CHAR(SYSDATE, 'HH24MISS')
		, ''
		, ''
		, ''
		, :c_trdat
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, TO_CHAR(SYSDATE, 'HH24MISS')
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, ''
		, TO_CHAR(SYSDATE, 'YYYYMMDD')
		, TO_CHAR(SYSDATE, 'HH24MISS')
