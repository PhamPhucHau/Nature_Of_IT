	;

	if (SQL_ERROR)
	{
		LOGGER(LOG_ERROR, "%d] INSERT GAT_SWSANYSND_LOG ERROR [%d", CPid, SQLCODE);
		EXEC SQL ROLLBACK WORK;
		return ABNORMAL;
	}
	EXEC SQL COMMIT WORK;
	LOGGER(LOG_DEBUG, "%d]End... ", CPid);
	return NORMAL;
}

void initCoreStructure(unsigned char x){
	memset(&ChnlHead, x, sizeof(ChnlHead));      
	memset(&MsgHead , x, sizeof(MsgHead ));  
	memset(&MsgFix  , x, sizeof(MsgFix  ));  
	memset(&MsgCom  , x, sizeof(MsgCom  ));  
	memset(&MsgData , x, sizeof(MsgData )); 
}

/*----------------------------------------------------------------------------*/
/* FUNCTION : alarm_handler                                                   */
/* SUBJECT  :                                                                 */
/* RETURN   : SUCCESS: NORMAL                                                 */
/*----------------------------------------------------------------------------*/
int alarm_handler()
{
	LOGGER(LOG_ERROR, "%d] called !!", CPid);
	signal(SIGALRM, alarm_handler);
	return NORMAL;
}


int check_running(const char *exeName){

	if(lock_fd >= 0) return 1;
    
	char lock_flg[100] = {0x00,};
	snprintf(lock_flg, sizeof(lock_flg), "/home/atmadm/.config/%s.lock", exeName);
	lock_fd = open(lock_flg,  O_RDWR | O_CREAT, 0666);
	if(lock_fd < 0) return 0;

	struct flock fl;
	memset(&fl, 0, sizeof(fl));
	fl.l_type = F_WRLCK;
	fl.l_whence = SEEK_SET;

	if(fcntl(lock_fd, F_SETLK, &fl) < 0){
		if(errno == EACCES || errno == EAGAIN) return -1; // another intance is running
		close(lock_fd);
		lock_fd = -1;
		return 0;
	}
	//write current PID to file
	ftruncate(lock_fd, 0);
	char buff[32];
	snprintf(buff, sizeof(buff), "%d
", getpid());
	write(lock_fd, buff, strlen(buff));
	return 1;
}

