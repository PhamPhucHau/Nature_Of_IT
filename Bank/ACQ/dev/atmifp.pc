/*----------------------------------------------------------------------------*/
int getKeyData(char* key, char* value)
{
EXEC SQL BEGIN DECLARE SECTION;
	char c_value[200 + 1] = {0x00, };	
	char c_key[20 + 1] = {0x00, };	
EXEC SQL END DECLARE SECTION;

	memcpy(c_key, key, strlen(key) );
	logging(logfp, "%s] c_key : [%s", __func__, c_key);

	EXEC SQL
	SELECT ATM_ESTBLS_CTT
	  INTO :c_value
	  FROM DBOWN.GAT_SWSCONF_INF
	 WHERE SH_LCL_CORP_C = 130
	   AND ATM_ESTBLS_TRX_C = 'CONF'
	   AND ATM_ESTBLS_ID = :c_key   
	;

	if (SQL_ERROR)
	{
		if (SQL_NOTFOUND)
		{
			logging(logfp, "%s] DATA NOT FOUND : [%s", __func__, c_key);
			return ABNORMAL;
		}

		logging(logfp, "%s] SELECT SQL ERROR [%d", __func__, SQLCODE);
		return ABNORMAL;
	}

	rtrimString(c_value);

	memcpy(value, c_value, strlen(c_value) );
	logging(logfp, "%s] c_value : [%s", __func__, c_value);
	
	return NORMAL;
}


