int loadDesKey()
{
	memset(AESClearKey, 0x00, sizeof(AESClearKey));
	if (getKeyData("ZPK_AQC_AES", AESClearKey) == ABNORMAL)   
		return ABNORMAL;    
    return NORMAL;
}

int loadConfig(){

	char port[4 + 1] = {0x00,};
	memset(hsm_ip, 0x00, sizeof(hsm_ip));
	if (getConfigData("HSM_HOSTPORT3", hsm_port) == ABNORMAL)   
		return ABNORMAL;    

	if (getConfigData("HSM_HOSTADDR3", hsm_ip) == ABNORMAL)   
		return ABNORMAL;    
	
	if (getConfigData("HSM_INST_CNT", hsm_svc_cnt) == ABNORMAL)   
		return ABNORMAL;    
    return NORMAL;

}

/*----------------------------------------------------------------------------*/
/* FUNCTION : getLogLevel()                                                     */
/* SUBJECT  : Get log level                                                   */
/* ARGUMENT :                                                                 */
/* RETURN   : SUCCESS: NORMAL                                                 */
/*----------------------------------------------------------------------------*/
int getLogLevel()
{
	EXEC SQL BEGIN DECLARE SECTION;
		char loglevel[80] = {0x00, };
	EXEC SQL END DECLARE SECTION;

	EXEC SQL
	SELECT ATM_ESTBLS_NM
	  INTO :loglevel
	  FROM DBOWN.GAT_SWSCONF_INF
	 WHERE SH_LCL_CORP_C = 130
	   AND ATM_ESTBLS_TRX_C = 'CONF'
	   AND ATM_ESTBLS_ID = 'ACQ_LOGLVL'	
	;    

	if (SQL_ERROR)
	{
		custLoglevel = LOG_INFO;
		LOGGER(LOG_ERROR, "SELECT SQL ERROR [%d", SQLCODE);
	}else{
		trimString(loglevel);
		custLoglevel = atoi(loglevel);
	}

	return NORMAL;
}


int IsAvaibleToRead(int socket_id){
	char peek_buff[1];
	fd_set rset;
	struct timeval tval;
	int chkIdx, ret;
	for ( chkIdx = 0; chkIdx < 5; chkIdx++ ) {
		tval.tv_sec  = 60 ;   
		tval.tv_usec = 0 ;  
		FD_ZERO(&rset);   
		FD_SET(socket_id , &rset);   
		ret = select(socket_id+1 , &rset , (fd_set *)NULL , (fd_set *)NULL , &tval);
		if ( (ret > 0) && (FD_ISSET(socket_id, &rset)) ) {
			int bytes = recv(socket_id, peek_buff,1, MSG_PEEK);
			if( bytes > 0 ) return 1;
		} 
	}
	LOGGER(LOG_INFO,  "No Available Data To Read"," ");
	return -1;
	
}
